//@version=6
indicator("Quasimodo v2 — 3 Wave + W4 Entry", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
//  QUASIMODO v2 — 3 WAVE COUNT + WAVE 4 ENTRY
//
//  Таны зурсан загвар:
//
//            3 (head)
//           /\      4  ← ЭНД SELL
//        2 /  \    /\
//       /\/    \  /  \
//    1 /        \/    \
//   /\/         BOS    \  доошоо...
//  /
//
//  Логик (bearish):
//   1-2-3: ГУРВАН дараалан ӨСӨХ оргил (wave count) — 1 < 2 < 3
//   3 = head (хамгийн өндөр, liquidity grab)
//   3-ын дараа үнэ сүүлийн хонхорыг эвдэнэ (BOS) ⬇
//   4 = үнэ 2-ын түвшин (LS бүс) рүү буцаж ирэх 4 дэх wave
//   → 4 дээр SELL. SL = 3 (head) дээр. TP = R:R
//
//  Bullish = яг толин туссан (3 дараалан буурах хонхор → BOS ⬆ → W4 BUY)
//
//  v1-ээс ялгаа: v1 нь 2 оргил хардаг. v2 нь ГУРВАН дараалсан
//  өсөх оргил шаардана — trend exhaustion илүү баталгаатай,
//  fake pattern цөөн, winrate өндөр.
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_PAT  = "① Wave / Pattern"
string G_ENT  = "② Wave 4 Entry"
string G_RISK = "③ Risk"
string G_VIS  = "④ Visual"

// ─── Pattern Inputs ───
int   piv_len  = input.int(5,    "Pivot Length", minval=2, maxval=15, group=G_PAT)
float w_min    = input.float(0.15,"Wave min өсөлт (ATR×)", minval=0.0, step=0.05, group=G_PAT,
     tooltip="Оргил бүр өмнөхөөсөө хамгийн багадаа ATR×энэ хэмжээгээр өндөр байх (bearish-д)")
int   max_age  = input.int(80,   "W4 хүлээх хугацаа (bars)", minval=20, maxval=300, group=G_PAT)

// ─── Entry Inputs ───
float ls_zone  = input.float(0.5,  "W4 entry бүс (ATR×)", minval=0.1, step=0.1, group=G_ENT,
     tooltip="Wave 2-ын түвшний эргэн тойрны бүс — W4 энд хүрэхэд entry")
bool  use_rev  = input.bool(true,  "Reversal candle баталгаа", group=G_ENT)
float rev_body = input.float(0.35, "Reversal биет min", minval=0.2, maxval=0.8, step=0.05, group=G_ENT)
bool  use_htf  = input.bool(false, "HTF EMA шүүлтүүр", group=G_ENT)
string htf_tf  = input.timeframe("60", "HTF Timeframe", group=G_ENT)
int   htf_len  = input.int(50, "HTF EMA Length", minval=1, group=G_ENT)

// ─── Risk ───
int   atr_len = input.int(14,    "ATR Length", minval=1, group=G_RISK)
float sl_buf  = input.float(0.5, "SL buffer head-ээс (ATR×)", minval=0.0, step=0.1, group=G_RISK)
float rr1     = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_RISK)
float rr2     = input.float(2.0, "TP2 R:R", minval=1.0, step=0.5, group=G_RISK)

// ─── Visual ───
color col_bull = input.color(color.rgb(38, 200, 120), "Bull", group=G_VIS)
color col_bear = input.color(color.rgb(240, 80, 60),  "Bear", group=G_VIS)
bool  show_waves = input.bool(true, "Wave дугаар (1,2,3) харуулах", group=G_VIS)
bool  show_ls    = input.bool(true, "W4 entry бүс харуулах", group=G_VIS)
bool  show_dash  = input.bool(true, "Dashboard", group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
// PIVOT TRACKING — сүүлийн 3 оргил, 3 хонхор
// ═══════════════════════════════════════════════════════════════════

float atr_v   = ta.atr(atr_len)
float htf_ema = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_len), lookahead=barmerge.lookahead_off)
bool  f_htf_l = not use_htf or close > htf_ema
bool  f_htf_s = not use_htf or close < htf_ema

float ph = ta.pivothigh(high, piv_len, piv_len)
float pl = ta.pivotlow(low,   piv_len, piv_len)

// Оргилууд: h1 = хамгийн шинэ, h3 = хамгийн хуучин
var float h1 = na
var float h2 = na
var float h3 = na
var int   h1_bar = na
var int   h2_bar = na
var int   h3_bar = na
// Хонхорууд
var float l1 = na
var float l2 = na
var float l3 = na
var int   l1_bar = na
var int   l2_bar = na
var int   l3_bar = na

if not na(ph)
    h3     := h2
    h3_bar := h2_bar
    h2     := h1
    h2_bar := h1_bar
    h1     := ph
    h1_bar := bar_index - piv_len
if not na(pl)
    l3     := l2
    l3_bar := l2_bar
    l2     := l1
    l2_bar := l1_bar
    l1     := pl
    l1_bar := bar_index - piv_len

// ═══════════════════════════════════════════════════════════════════
// 3-WAVE STRUCTURE + BOS
// ═══════════════════════════════════════════════════════════════════

// BEARISH: h3 < h2 < h1 гурван дараалан өсөх оргил (h1 = wave 3 head)
//          + оргилууд хоорондоо хонхроор тусгаарлагдсан (дараалал зөв)
//          + BOS: close < сүүлийн хонхор (l1)
bool bear_3wave = not na(h1) and not na(h2) and not na(h3) and
     h1 > h2 + w_min * atr_v and h2 > h3 + w_min * atr_v and
     not na(h1_bar) and not na(h2_bar) and not na(h3_bar) and
     h3_bar < h2_bar and h2_bar < h1_bar

// BULLISH: l3 > l2 > l1 гурван дараалан буурах хонхор (l1 = wave 3 head доод)
bool bull_3wave = not na(l1) and not na(l2) and not na(l3) and
     l1 < l2 - w_min * atr_v and l2 < l3 - w_min * atr_v and
     not na(l1_bar) and not na(l2_bar) and not na(l3_bar) and
     l3_bar < l2_bar and l2_bar < l1_bar

// ═══════════════════════════════════════════════════════════════════
// QM STATE MACHINE
// ═══════════════════════════════════════════════════════════════════

var int   qm_state = 0     // 0=idle, 1=bear armed (W4 хүлээж), -1=bull armed
var float qm_ls    = na    // W4 entry түвшин (wave 2)
var float qm_head  = na    // wave 3 head (SL invalidation)
var int   qm_bar   = na
var box   ls_box   = na
var line  head_ln  = na

// ─── BEARISH арматур: 3 wave + BOS доошоо ───
bool bear_bos = bear_3wave and not na(l1) and close < l1 and qm_state == 0 and h1_bar > l1_bar

if bear_bos
    qm_state := 1
    qm_ls    := h2                  // Wave 2 оргил = W4 entry түвшин
    qm_head  := h1                  // Wave 3 head
    qm_bar   := bar_index
    if show_waves
        label.new(h3_bar, h3, "1", color=color.new(col_bear, 55), textcolor=color.white, style=label.style_label_down, size=size.small)
        label.new(h2_bar, h2, "2", color=color.new(col_bear, 45), textcolor=color.white, style=label.style_label_down, size=size.small)
        label.new(h1_bar, h1, "3 HEAD", color=color.new(col_bear, 20), textcolor=color.white, style=label.style_label_down, size=size.normal)
    if show_ls
        box.delete(ls_box)
        ls_box := box.new(bar_index, qm_ls + ls_zone * atr_v, bar_index + max_age, qm_ls - ls_zone * atr_v,
             border_color=color.new(col_bear, 50), bgcolor=color.new(col_bear, 88))
        line.delete(head_ln)
        head_ln := line.new(bar_index, qm_head, bar_index + max_age, qm_head, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ─── BULLISH арматур: 3 wave доошоо + BOS дээшээ ───
bool bull_bos = bull_3wave and not na(h1) and close > h1 and qm_state == 0 and l1_bar > h1_bar

if bull_bos
    qm_state := -1
    qm_ls    := l2                  // Wave 2 хонхор = W4 entry түвшин
    qm_head  := l1                  // Wave 3 head (доод)
    qm_bar   := bar_index
    if show_waves
        label.new(l3_bar, l3, "1", color=color.new(col_bull, 55), textcolor=color.white, style=label.style_label_up, size=size.small)
        label.new(l2_bar, l2, "2", color=color.new(col_bull, 45), textcolor=color.white, style=label.style_label_up, size=size.small)
        label.new(l1_bar, l1, "3 HEAD", color=color.new(col_bull, 20), textcolor=color.white, style=label.style_label_up, size=size.normal)
    if show_ls
        box.delete(ls_box)
        ls_box := box.new(bar_index, qm_ls + ls_zone * atr_v, bar_index + max_age, qm_ls - ls_zone * atr_v,
             border_color=color.new(col_bull, 50), bgcolor=color.new(col_bull, 88))
        line.delete(head_ln)
        head_ln := line.new(bar_index, qm_head, bar_index + max_age, qm_head, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ═══════════════════════════════════════════════════════════════════
// WAVE 4 ENTRY
// ═══════════════════════════════════════════════════════════════════

float rng  = high - low
float body = math.abs(close - open)
bool  rev_bull_c = not use_rev or (close > open and rng > 0 and body / rng >= rev_body)
bool  rev_bear_c = not use_rev or (close < open and rng > 0 and body / rng >= rev_body)

bool long_entry  = false
bool short_entry = false
float entry_p    = na
float sl_p       = na

// Bearish: W4 = үнэ wave2 бүсэд дээшээ хүрч + bear reversal лаа
if qm_state == 1
    if close > qm_head or bar_index - qm_bar > max_age
        qm_state := 0
        box.delete(ls_box)
        line.delete(head_ln)
    else if high >= qm_ls - ls_zone * atr_v and close < qm_head and rev_bear_c and f_htf_s
        short_entry := true
        entry_p     := close
        sl_p        := qm_head + sl_buf * atr_v
        qm_state    := 0

// Bullish: W4 = үнэ wave2 бүсэд доошоо хүрч + bull reversal лаа
if qm_state == -1
    if close < qm_head or bar_index - qm_bar > max_age
        qm_state := 0
        box.delete(ls_box)
        line.delete(head_ln)
    else if low <= qm_ls + ls_zone * atr_v and close > qm_head and rev_bull_c and f_htf_l
        long_entry := true
        entry_p    := close
        sl_p       := qm_head - sl_buf * atr_v
        qm_state   := 0

// ─── TP ───
float risk_l = long_entry  ? entry_p - sl_p : na
float tp1_l  = long_entry  ? entry_p + risk_l * rr1 : na
float tp2_l  = long_entry  ? entry_p + risk_l * rr2 : na
float risk_s = short_entry ? sl_p - entry_p : na
float tp1_s  = short_entry ? entry_p - risk_s * rr1 : na
float tp2_s  = short_entry ? entry_p - risk_s * rr2 : na

// ─── Drawing ───
var line  e_ln  = na
var line  sl_ln = na
var line  t1_ln = na
var line  t2_ln = na
var label e_lb  = na
var label sl_lb = na
var label t1_lb = na
var label t2_lb = na

f_draw(float ep, float sp, float t1, float t2, color c) =>
    line.delete(e_ln)
    line.delete(sl_ln)
    line.delete(t1_ln)
    line.delete(t2_ln)
    label.delete(e_lb)
    label.delete(sl_lb)
    label.delete(t1_lb)
    label.delete(t2_lb)
    int r = bar_index + 30
    e  = line.new(bar_index, ep, r, ep, color=c,           width=2)
    s  = line.new(bar_index, sp, r, sp, color=color.red,   width=1, style=line.style_dashed)
    a  = line.new(bar_index, t1, r, t1, color=color.green, width=1, style=line.style_dashed)
    b  = line.new(bar_index, t2, r, t2, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    el = label.new(r, ep, "Entry " + str.tostring(ep, format.mintick), color=color.new(c, 75),          textcolor=color.white, style=label.style_label_left, size=size.small)
    sl = label.new(r, sp, "SL "    + str.tostring(sp, format.mintick), color=color.new(color.red, 75),  textcolor=color.white, style=label.style_label_left, size=size.small)
    l1_ = label.new(r, t1, "TP1 "  + str.tostring(t1, format.mintick), color=color.new(color.green,75), textcolor=color.white, style=label.style_label_left, size=size.small)
    l2_ = label.new(r, t2, "TP2 "  + str.tostring(t2, format.mintick), color=color.new(color.green,85), textcolor=color.white, style=label.style_label_left, size=size.small)
    [e, s, a, b, el, sl, l1_, l2_]

if long_entry and risk_l > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_l, tp2_l, col_bull)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

if short_entry and risk_s > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_s, tp2_s, col_bear)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

// ─── Signal labels: W4 дээр ───
plotshape(long_entry,  "W4 LONG",  shape.labelup,   location.belowbar, color.new(color.rgb(38,200,120), 0), textcolor=color.white, text="BUY\nW4", size=size.normal)
plotshape(short_entry, "W4 SHORT", shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60),  0), textcolor=color.white, text="SELL\nW4", size=size.normal)

if short_entry
    label.new(bar_index, high + atr_v * 2.2, "4", color=color.new(col_bear, 35), textcolor=color.white, style=label.style_label_down, size=size.normal)
if long_entry
    label.new(bar_index, low - atr_v * 2.2, "4", color=color.new(col_bull, 35), textcolor=color.white, style=label.style_label_up, size=size.normal)

// ─── Winrate Tracking ───
var int   trade_dir  = 0
var float trade_sl   = na
var float trade_tp1  = na
var float trade_tp2  = na
var int   wins       = 0
var int   losses     = 0
var int   tp2_hits   = 0
var bool  tp1_done   = false

if long_entry and risk_l > 0
    trade_dir := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_l
    trade_tp2 := tp2_l
    tp1_done  := false
if short_entry and risk_s > 0
    trade_dir := -1
    trade_sl  := sl_p
    trade_tp1 := tp1_s
    trade_tp2 := tp2_s
    tp1_done  := false

if trade_dir == 1 and not (long_entry or short_entry)
    if not tp1_done and high >= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and high >= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if low <= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

if trade_dir == -1 and not (long_entry or short_entry)
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 7, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string st_txt = qm_state == 1 ? "🔻 3-Wave олдсон — W4 хүлээж" : qm_state == -1 ? "🔺 3-Wave олдсон — W4 хүлээж" : trade_dir != 0 ? (trade_dir == 1 ? "📈 LONG нээлттэй" : "📉 SHORT нээлттэй") : "○ 1-2-3 wave хайж байна"
    color  st_col = qm_state == 1 ? col_bear : qm_state == -1 ? col_bull : color.rgb(160,175,220)
    string ls_txt = qm_state != 0 ? str.tostring(qm_ls, format.mintick) : "—"
    string hd_txt = qm_state != 0 ? str.tostring(qm_head, format.mintick) : "—"
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? col_bull : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    string tt_txt = str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits)
    table.cell(dash, 0, 0, " QM v2 — 3 Wave", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Төлөв",         bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, st_txt,           bgcolor=color.rgb(14,17,28), text_color=st_col, text_size=size.small)
    table.cell(dash, 0, 2, " W4 entry (W2)", bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, ls_txt,           bgcolor=color.rgb(10,10,18), text_color=color.rgb(255,200,0), text_size=size.small)
    table.cell(dash, 0, 3, " Head W3 (SL)",  bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, hd_txt,           bgcolor=color.rgb(14,17,28), text_color=color.rgb(220,40,80), text_size=size.small)
    table.cell(dash, 0, 4, " Winrate",       bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, wr_txt,           bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 5, " Арилжаа",       bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 5, tt_txt,           bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 6, " ATR",           bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(atr_v, format.mintick), bgcolor=color.rgb(10,10,18), text_color=color.rgb(160,175,220), text_size=size.small)

// ─── Alerts ───
alertcondition(long_entry,  "QM v2 LONG (W4)",  "Quasimodo v2 W4 LONG — {{ticker}} @ {{close}}")
alertcondition(short_entry, "QM v2 SHORT (W4)", "Quasimodo v2 W4 SHORT — {{ticker}} @ {{close}}")
alertcondition(qm_state != 0 and qm_state[1] == 0, "3-Wave олдлоо", "QM v2: 1-2-3 wave + BOS үүслээ — {{ticker}}, W4 хүлээж байна")
