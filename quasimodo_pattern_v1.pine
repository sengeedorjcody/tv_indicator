//@version=6
indicator("Quasimodo Pattern v1 — QM Entry", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
//  QUASIMODO (QM / Over-and-Under) PATTERN v1
//
//  BEARISH QM бүтэц:                    BULLISH QM бүтэц:
//        HH (head)                          ⬇ эхлэл
//       /  \                            \      /\      ⬆
//   H1 /    \    ← entry (LS)            \    /  \    / entry (LS)
//     /\     \   /                        \  /    \  /
//    /  \     \ /                          \/      \/
//        \     LL ← BOS                    LL       HL
//         L1                                (head)   ← BOS дээшээ
//
//  Алхам (bearish жишээ):
//   1. H1 (эхний оргил) үүснэ
//   2. L1 (завсрын хонхор) үүснэ
//   3. HH — H1-ээс өндөр шинэ оргил (head) = liquidity grab
//   4. Үнэ L1-ийг доош эвдэнэ (BOS) — бүтэц өөрчлөгдсөн
//   5. Үнэ H1 (left shoulder) түвшин рүү буцаж ирэхэд SELL
//      SL = head дээр, TP = BOS доод цэг / R:R
//
//  Яагаад хүчтэй вэ: Head = stop hunt (liquidity цуглуулалт),
//  BOS = чиглэл өөрчлөгдсөн баталгаа, LS retest = сайн үнэ +
//  тодорхой invalidation (head). Institutional reversal загвар.
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_PAT  = "① Pattern тохиргоо"
string G_ENT  = "② Entry тохиргоо"
string G_RISK = "③ Risk"
string G_VIS  = "④ Visual"

// ─── Pattern Inputs ───
int   piv_len    = input.int(5,   "Pivot Length", minval=2, maxval=15, group=G_PAT,
     tooltip="Оргил/хонхор таних мэдрэг байдал. Бага = олон жижиг pattern, их = том pattern")
int   max_age    = input.int(80,  "Pattern хүчинтэй хугацаа (bars)", minval=20, maxval=300, group=G_PAT,
     tooltip="BOS-оос хойш энэ хугацаанд LS retest болоогүй бол pattern хүчингүй")
float head_min   = input.float(0.2, "Head min өндөр (ATR×)", minval=0.0, step=0.1, group=G_PAT,
     tooltip="Head нь H1-ээс хамгийн багадаа ATR×энэ хэмжээгээр өндөр байх. Сул head = сул pattern")

// ─── Entry Inputs ───
float ls_zone    = input.float(0.5, "LS entry бүс (ATR×)", minval=0.1, step=0.1, group=G_ENT,
     tooltip="Left shoulder түвшний эргэн тойронд ATR×энэ хэмжээний бүс — үнэ энд хүрэхэд entry")
bool  use_rev    = input.bool(true, "Reversal candle баталгаа", group=G_ENT,
     tooltip="LS бүсэд эргэлтийн лаа (зөв чиглэлийн биет ≥ 35%) хаагдахыг хүлээнэ")
float rev_body   = input.float(0.35, "Reversal биет min", minval=0.2, maxval=0.8, step=0.05, group=G_ENT)
bool  use_htf    = input.bool(false, "HTF EMA шүүлтүүр", group=G_ENT)
string htf_tf    = input.timeframe("60", "HTF Timeframe", group=G_ENT)
int   htf_len    = input.int(50, "HTF EMA Length", minval=1, group=G_ENT)

// ─── Risk ───
int   atr_len   = input.int(14,    "ATR Length", minval=1, group=G_RISK)
float sl_buf    = input.float(0.5, "SL buffer head-ээс (ATR×)", minval=0.0, step=0.1, group=G_RISK)
float rr1       = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_RISK)
float rr2       = input.float(2.0, "TP2 R:R", minval=1.0, step=0.5, group=G_RISK)

// ─── Visual ───
color col_bull = input.color(color.rgb(38, 200, 120), "Bull", group=G_VIS)
color col_bear = input.color(color.rgb(240, 80, 60),  "Bear", group=G_VIS)
bool  show_pat = input.bool(true, "Pattern шугам зурах",   group=G_VIS)
bool  show_ls  = input.bool(true, "LS entry бүс харуулах", group=G_VIS)
bool  show_dash= input.bool(true, "Dashboard",             group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
// PIVOT TRACKING
// ═══════════════════════════════════════════════════════════════════

float atr_v = ta.atr(atr_len)
float htf_ema = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_len), lookahead=barmerge.lookahead_off)
bool f_htf_l = not use_htf or close > htf_ema
bool f_htf_s = not use_htf or close < htf_ema

float ph = ta.pivothigh(high, piv_len, piv_len)
float pl = ta.pivotlow(low,   piv_len, piv_len)

// Сүүлийн 3 pivot high/low хадгална (шинэ → хуучин)
var float ph1 = na
var float ph2 = na
var int   ph1_bar = na
var int   ph2_bar = na
var float pl1 = na
var float pl2 = na
var int   pl1_bar = na
var int   pl2_bar = na

if not na(ph)
    ph2     := ph1
    ph2_bar := ph1_bar
    ph1     := ph
    ph1_bar := bar_index - piv_len
if not na(pl)
    pl2     := pl1
    pl2_bar := pl1_bar
    pl1     := pl
    pl1_bar := bar_index - piv_len

// ═══════════════════════════════════════════════════════════════════
// QM STATE MACHINE
//  0 = idle
//  1 = bearish QM armed (BOS болсон, LS retest хүлээж)
// -1 = bullish QM armed
// ═══════════════════════════════════════════════════════════════════

var int   qm_state   = 0
var float qm_ls      = na    // left shoulder түвшин (entry)
var float qm_head    = na    // head (SL талын invalidation)
var float qm_bos     = na    // BOS түвшин (TP чиглэл)
var int   qm_bar     = na    // BOS болсон bar
var box   ls_box     = na
var line  head_ln    = na

// ─── BEARISH QM илрүүлэлт ───
// Нөхцөл: ph2 (H1) → pl1 (L1, H1-ийн дараа) → ph1 (HH head, > H1 + min) → close < L1 (BOS)
bool bear_struct = not na(ph1) and not na(ph2) and not na(pl1) and
     ph1 > ph2 + head_min * atr_v and
     not na(pl1_bar) and not na(ph2_bar) and not na(ph1_bar) and
     pl1_bar > ph2_bar and pl1_bar < ph1_bar

bool bear_bos = bear_struct and close < pl1 and qm_state == 0

if bear_bos
    qm_state := 1
    qm_ls    := ph2         // left shoulder = өмнөх оргил H1
    qm_head  := ph1         // head = HH
    qm_bos   := pl1         // эвдсэн түвшин
    qm_bar   := bar_index
    if show_pat
        line.new(ph2_bar, ph2, bar_index, ph2, color=color.new(col_bear, 30), width=1, style=line.style_dashed)
        label.new(ph1_bar, ph1, "QM Head", color=color.new(col_bear, 40), textcolor=color.white, style=label.style_label_down, size=size.small)
    if show_ls
        box.delete(ls_box)
        ls_box := box.new(bar_index, qm_ls + ls_zone * atr_v, bar_index + max_age, qm_ls - ls_zone * atr_v,
             border_color=color.new(col_bear, 50), bgcolor=color.new(col_bear, 88))
        line.delete(head_ln)
        head_ln := line.new(bar_index, qm_head, bar_index + max_age, qm_head, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ─── BULLISH QM илрүүлэлт ───
// Нөхцөл: pl2 (L1) → ph1 (H1, L1-ийн дараа) → pl1 (LL head, < L1 - min) → close > H1 (BOS)
bool bull_struct = not na(pl1) and not na(pl2) and not na(ph1) and
     pl1 < pl2 - head_min * atr_v and
     not na(ph1_bar) and not na(pl2_bar) and not na(pl1_bar) and
     ph1_bar > pl2_bar and ph1_bar < pl1_bar

bool bull_bos = bull_struct and close > ph1 and qm_state == 0

if bull_bos
    qm_state := -1
    qm_ls    := pl2         // left shoulder = өмнөх хонхор L1
    qm_head  := pl1         // head = LL
    qm_bos   := ph1
    qm_bar   := bar_index
    if show_pat
        line.new(pl2_bar, pl2, bar_index, pl2, color=color.new(col_bull, 30), width=1, style=line.style_dashed)
        label.new(pl1_bar, pl1, "QM Head", color=color.new(col_bull, 40), textcolor=color.white, style=label.style_label_up, size=size.small)
    if show_ls
        box.delete(ls_box)
        ls_box := box.new(bar_index, qm_ls + ls_zone * atr_v, bar_index + max_age, qm_ls - ls_zone * atr_v,
             border_color=color.new(col_bull, 50), bgcolor=color.new(col_bull, 88))
        line.delete(head_ln)
        head_ln := line.new(bar_index, qm_head, bar_index + max_age, qm_head, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ═══════════════════════════════════════════════════════════════════
// ENTRY: LS RETEST
// ═══════════════════════════════════════════════════════════════════

float rng  = high - low
float body = math.abs(close - open)
bool  rev_bull_c = not use_rev or (close > open and rng > 0 and body / rng >= rev_body)
bool  rev_bear_c = not use_rev or (close < open and rng > 0 and body / rng >= rev_body)

bool long_entry  = false
bool short_entry = false
float entry_p    = na
float sl_p       = na

// Bearish QM: үнэ LS бүсэд дээшээ хүрч + bear reversal лаа
if qm_state == 1
    // Хүчингүй болох: head давсан эсвэл хугацаа хэтэрсэн
    if close > qm_head or bar_index - qm_bar > max_age
        qm_state := 0
        box.delete(ls_box)
        line.delete(head_ln)
    else if high >= qm_ls - ls_zone * atr_v and close < qm_head and rev_bear_c and f_htf_s
        short_entry := true
        entry_p     := close
        sl_p        := qm_head + sl_buf * atr_v
        qm_state    := 0

// Bullish QM: үнэ LS бүсэд доошоо хүрч + bull reversal лаа
if qm_state == -1
    if close < qm_head or bar_index - qm_bar > max_age
        qm_state := 0
        box.delete(ls_box)
        line.delete(head_ln)
    else if low <= qm_ls + ls_zone * atr_v and close > qm_head and rev_bull_c and f_htf_l
        long_entry := true
        entry_p    := close
        sl_p       := qm_head - sl_buf * atr_v
        qm_state   := 0

// ─── TP ───
float risk_l = long_entry  ? entry_p - sl_p : na
float tp1_l  = long_entry  ? entry_p + risk_l * rr1 : na
float tp2_l  = long_entry  ? entry_p + risk_l * rr2 : na
float risk_s = short_entry ? sl_p - entry_p : na
float tp1_s  = short_entry ? entry_p - risk_s * rr1 : na
float tp2_s  = short_entry ? entry_p - risk_s * rr2 : na

// ─── Drawing ───
var line  e_ln  = na
var line  sl_ln = na
var line  t1_ln = na
var line  t2_ln = na
var label e_lb  = na
var label sl_lb = na
var label t1_lb = na
var label t2_lb = na

f_draw(float ep, float sp, float t1, float t2, color c) =>
    line.delete(e_ln)
    line.delete(sl_ln)
    line.delete(t1_ln)
    line.delete(t2_ln)
    label.delete(e_lb)
    label.delete(sl_lb)
    label.delete(t1_lb)
    label.delete(t2_lb)
    int r = bar_index + 30
    e  = line.new(bar_index, ep, r, ep, color=c,           width=2)
    s  = line.new(bar_index, sp, r, sp, color=color.red,   width=1, style=line.style_dashed)
    a  = line.new(bar_index, t1, r, t1, color=color.green, width=1, style=line.style_dashed)
    b  = line.new(bar_index, t2, r, t2, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    el = label.new(r, ep, "Entry " + str.tostring(ep, format.mintick), color=color.new(c, 75),          textcolor=color.white, style=label.style_label_left, size=size.small)
    sl = label.new(r, sp, "SL "    + str.tostring(sp, format.mintick), color=color.new(color.red, 75),  textcolor=color.white, style=label.style_label_left, size=size.small)
    l1 = label.new(r, t1, "TP1 "   + str.tostring(t1, format.mintick), color=color.new(color.green,75), textcolor=color.white, style=label.style_label_left, size=size.small)
    l2 = label.new(r, t2, "TP2 "   + str.tostring(t2, format.mintick), color=color.new(color.green,85), textcolor=color.white, style=label.style_label_left, size=size.small)
    [e, s, a, b, el, sl, l1, l2]

if long_entry and risk_l > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_l, tp2_l, col_bull)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

if short_entry and risk_s > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_s, tp2_s, col_bear)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

// ─── Signal labels ───
plotshape(long_entry,  "QM LONG",  shape.labelup,   location.belowbar, color.new(color.rgb(38,200,120), 0), textcolor=color.white, text="BUY\nQM", size=size.normal)
plotshape(short_entry, "QM SHORT", shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60),  0), textcolor=color.white, text="SELL\nQM", size=size.normal)

// ─── Winrate Tracking (TP1 = WIN + breakeven) ───
var int   trade_dir  = 0
var float trade_sl   = na
var float trade_tp1  = na
var float trade_tp2  = na
var int   wins       = 0
var int   losses     = 0
var int   tp2_hits   = 0
var bool  tp1_done   = false

if long_entry and risk_l > 0
    trade_dir := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_l
    trade_tp2 := tp2_l
    tp1_done  := false
if short_entry and risk_s > 0
    trade_dir := -1
    trade_sl  := sl_p
    trade_tp1 := tp1_s
    trade_tp2 := tp2_s
    tp1_done  := false

if trade_dir == 1 and not (long_entry or short_entry)
    if not tp1_done and high >= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and high >= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if low <= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

if trade_dir == -1 and not (long_entry or short_entry)
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 7, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string st_txt = qm_state == 1 ? "🔻 Bearish QM — LS хүлээж" : qm_state == -1 ? "🔺 Bullish QM — LS хүлээж" : trade_dir != 0 ? (trade_dir == 1 ? "📈 LONG нээлттэй" : "📉 SHORT нээлттэй") : "○ Pattern хайж байна"
    color  st_col = qm_state == 1 ? col_bear : qm_state == -1 ? col_bull : color.rgb(160,175,220)
    string ls_txt = qm_state != 0 ? str.tostring(qm_ls, format.mintick) : "—"
    string hd_txt = qm_state != 0 ? str.tostring(qm_head, format.mintick) : "—"
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? col_bull : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    string tt_txt = str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits)
    table.cell(dash, 0, 0, " Quasimodo v1", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Төлөв",      bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, st_txt,        bgcolor=color.rgb(14,17,28), text_color=st_col, text_size=size.small)
    table.cell(dash, 0, 2, " LS (entry)", bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, ls_txt,        bgcolor=color.rgb(10,10,18), text_color=color.rgb(255,200,0), text_size=size.small)
    table.cell(dash, 0, 3, " Head (SL)",  bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, hd_txt,        bgcolor=color.rgb(14,17,28), text_color=color.rgb(220,40,80), text_size=size.small)
    table.cell(dash, 0, 4, " Winrate",    bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, wr_txt,        bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 5, " Арилжаа",    bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 5, tt_txt,        bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 6, " ATR",        bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(atr_v, format.mintick), bgcolor=color.rgb(10,10,18), text_color=color.rgb(160,175,220), text_size=size.small)

// ─── Alerts ───
alertcondition(long_entry,  "QM LONG",  "Quasimodo LONG — {{ticker}} @ {{close}}")
alertcondition(short_entry, "QM SHORT", "Quasimodo SHORT — {{ticker}} @ {{close}}")
alertcondition(qm_state != 0 and qm_state[1] == 0, "QM Pattern олдлоо", "Quasimodo pattern үүслээ — {{ticker}}, LS retest хүлээж байна")
