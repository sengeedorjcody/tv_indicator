//@version=6
indicator("AAD Pattern v4 — Clean Big Parallel Channel", overlay=true, max_lines_count=200, max_labels_count=100, max_boxes_count=50)

// ═══════════════════════════════════════════════════════════════════
//  AAD PATTERN v4 — ЦЭВЭР, ТОМ ПАРАЛЛЕЛЬ СУВАГ
//
//  v3-ийн шуугианыг арилгасан:
//   ① ТОМ суваг = 3+3 цэгээр батлагдана (3 өсөх HL + 3 өсөх HH)
//      · Цэгүүд нэг шулуун дээр байх (collinear шалгалт)
//      · Хоёр шугам ПАРАЛЛЕЛЬ байх (налуугийн зөрүү бага)
//   ② Label зөвхөн ИДЭВХТЭЙ pattern дээр — цуцлагдахад УСТГАНА
//   ③ Pattern хоорондын cooldown — дараалсан спам арилна
//
//  Дараалал (SELL):
//   ТОМ параллель өсөх суваг → доошоо задрал → хүчтэй уналт
//   → жижиг өсөх суваг → жижиг суваг задрал → SELL
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_BIG = "① Том параллель суваг"
string G_IMP = "② Impulse"
string G_SML = "③ Жижиг суваг"
string G_RSK = "④ Risk"
string G_VIS = "⑤ Visual"

// ─── Big Channel ───
int   big_piv  = input.int(6,     "Том суваг pivot", minval=4, maxval=15, group=G_BIG)
float lin_tol  = input.float(0.6, "Шулуун байх tolerance (ATR×)", minval=0.1, step=0.1, group=G_BIG,
     tooltip="Дунд цэг (HL2/HH2) нь захын 2 цэгийг холбосон шулуунаас энэ зайд байх — жинхэнэ trendline")
float par_tol  = input.float(0.35,"Параллель tolerance", minval=0.05, step=0.05, group=G_BIG,
     tooltip="Дээд, доод шугамын налуугийн зөрүү (ATR/bar-аар) — бага байх тусам параллель")
int   cool_dn  = input.int(30,    "Pattern cooldown (bars)", minval=0, maxval=200, group=G_BIG)
bool  do_sell  = input.bool(true, "SELL pattern", group=G_BIG)
bool  do_buy   = input.bool(true, "BUY pattern",  group=G_BIG)

// ─── Impulse ───
float imp_min  = input.float(1.5, "Impulse min (ATR×)", minval=0.5, step=0.25, group=G_IMP)
int   imp_wait = input.int(40,    "Impulse max хугацаа", minval=10, maxval=150, group=G_IMP)

// ─── Small Channel ───
int   sml_piv  = input.int(2,  "Жижиг суваг pivot", minval=1, maxval=5, group=G_SML)
int   sml_wait = input.int(50, "Жижиг суваг max хугацаа", minval=15, maxval=200, group=G_SML)

// ─── Risk ───
float bd_buf  = input.float(0.1, "Задрал buffer (ATR×)", minval=0.0, step=0.05, group=G_RSK)
int   atr_len = input.int(14,    "ATR Length", minval=1, group=G_RSK)
float sl_buf  = input.float(0.3, "SL buffer (ATR×)", minval=0.0, step=0.1, group=G_RSK)
float rr1     = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_RSK)
float rr2     = input.float(2.0, "TP2 R:R", minval=1.0, step=0.5, group=G_RSK)

// ─── Visual ───
color col_bull  = input.color(color.rgb(38, 200, 120), "Bull", group=G_VIS)
color col_bear  = input.color(color.rgb(240, 80, 60),  "Bear", group=G_VIS)
bool  show_dash = input.bool(true, "Dashboard", group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
float atr_v = ta.atr(atr_len)

// ─── ТОМ суваг: сүүлийн 3 pivot high + 3 pivot low ───
float bph = ta.pivothigh(high, big_piv, big_piv)
float bpl = ta.pivotlow(low,   big_piv, big_piv)

var float h1 = na
var float h2 = na
var float h3 = na
var int   h1b = na
var int   h2b = na
var int   h3b = na
var float l1 = na
var float l2 = na
var float l3 = na
var int   l1b = na
var int   l2b = na
var int   l3b = na

if not na(bph)
    h3  := h2
    h3b := h2b
    h2  := h1
    h2b := h1b
    h1  := bph
    h1b := bar_index - big_piv
if not na(bpl)
    l3  := l2
    l3b := l2b
    l2  := l1
    l2b := l1b
    l1  := bpl
    l1b := bar_index - big_piv

// ─── Том ӨСӨХ параллель суваг (SELL setup) ───
// 3 өсөх HL + 3 өсөх HH + collinear + parallel
bool lows_ok  = not na(l1) and not na(l2) and not na(l3) and l1 > l2 and l2 > l3
bool highs_ok = not na(h1) and not na(h2) and not na(h3) and h1 > h2 and h2 > h3

float slope_l = lows_ok  and l1b != l3b ? (l1 - l3) / (l1b - l3b) : na
float slope_h = highs_ok and h1b != h3b ? (h1 - h3) / (h1b - h3b) : na

// Collinear: дунд цэг шулуунаас хол биш
bool lin_l = lows_ok  and not na(slope_l) and math.abs(l2 - (l3 + slope_l * (l2b - l3b))) <= lin_tol * atr_v
bool lin_h = highs_ok and not na(slope_h) and math.abs(h2 - (h3 + slope_h * (h2b - h3b))) <= lin_tol * atr_v

// Parallel: налуугийн зөрүү бага
bool parallel = not na(slope_l) and not na(slope_h) and
     math.abs(slope_l - slope_h) <= par_tol * atr_v / math.max(big_piv * 2, 1)

bool big_asc  = lows_ok and highs_ok and slope_l > 0 and lin_l and lin_h and parallel

// Том БУУРАХ параллель суваг (BUY setup)
bool lows_dn  = not na(l1) and not na(l2) and not na(l3) and l1 < l2 and l2 < l3
bool highs_dn = not na(h1) and not na(h2) and not na(h3) and h1 < h2 and h2 < h3
bool lin_l2   = lows_dn  and not na(slope_l) and math.abs(l2 - (l3 + slope_l * (l2b - l3b))) <= lin_tol * atr_v
bool lin_h2   = highs_dn and not na(slope_h) and math.abs(h2 - (h3 + slope_h * (h2b - h3b))) <= lin_tol * atr_v
bool big_desc = lows_dn and highs_dn and slope_h < 0 and lin_l2 and lin_h2 and parallel

// Support/Resistance projection (дундаж налуугаар — жинхэнэ параллель)
float avg_slope = not na(slope_l) and not na(slope_h) ? (slope_l + slope_h) / 2 : na
float sup_now = big_asc  and not na(avg_slope) ? l3 + avg_slope * (bar_index - l3b) : na
float res_now = big_desc and not na(avg_slope) ? h3 + avg_slope * (bar_index - h3b) : na

// ─── Жижиг сувгийн pivots ───
float sph = ta.pivothigh(high, sml_piv, sml_piv)
float spl = ta.pivotlow(low,   sml_piv, sml_piv)

var float sh1 = na
var float sh2 = na
var int   sh1b = na
var int   sh2b = na
var float sl1 = na
var float sl2 = na
var int   sl1b = na
var int   sl2b = na

if not na(sph)
    sh2  := sh1
    sh2b := sh1b
    sh1  := sph
    sh1b := bar_index - sml_piv
if not na(spl)
    sl2  := sl1
    sl2b := sl1b
    sl1  := spl
    sl1b := bar_index - sml_piv

// ═══════════════════════════════════════════════════════════════════
// STATE MACHINE + идэвхтэй pattern-ийн зурлагын менежмент
// ═══════════════════════════════════════════════════════════════════

var int   pdir      = 0
var int   phase     = 0
var float break_px  = na
var float ext_px    = na
var int   phase_bar = na
var int   last_done = -99999   // сүүлийн pattern дууссан bar (cooldown)
var float sml_slope = na
var float sml_top   = na
var float sml_bot   = na

// Идэвхтэй pattern-ийн зурлагууд — цуцлагдахад бүгд устана
var line  big_a  = na
var line  big_b  = na
var line  sml_a  = na
var line  sml_b  = na
var array<label> pat_lbls = array.new<label>()

f_clear_pattern() =>
    line.delete(big_a)
    line.delete(big_b)
    line.delete(sml_a)
    line.delete(sml_b)
    if array.size(pat_lbls) > 0
        for i = 0 to array.size(pat_lbls) - 1
            label.delete(array.get(pat_lbls, i))
        array.clear(pat_lbls)

f_add_lbl(label lb) =>
    array.push(pat_lbls, lb)

// ─── ① Том суваг задрах ───
bool cd_ok = bar_index - last_done >= cool_dn

bool sell_break = do_sell and big_asc and not na(sup_now) and close < sup_now - bd_buf * atr_v and pdir == 0 and cd_ok
bool buy_break  = do_buy and big_desc and not na(res_now) and close > res_now + bd_buf * atr_v and pdir == 0 and cd_ok

if sell_break
    f_clear_pattern()
    pdir      := 1
    phase     := 1
    break_px  := close
    ext_px    := low
    phase_bar := bar_index
    // ПАРАЛЛЕЛЬ суваг зурах: support (l3→projection), resistance (ижил налуу, h1-ээр)
    big_a := line.new(l3b, l3, bar_index, sup_now, color=color.new(col_bear, 10), width=2)
    float res_anchor = h1 - avg_slope * (h1b - l3b)   // h1 цэгийг l3b bar-т шилжүүлсэн өндөр
    big_b := line.new(l3b, res_anchor, bar_index, res_anchor + avg_slope * (bar_index - l3b), color=color.new(col_bear, 10), width=2)
    f_add_lbl(label.new(bar_index, low, "① Суваг задарлаа", color=color.new(col_bear, 25), textcolor=color.white, style=label.style_label_up, size=size.small))

if buy_break and pdir == 0
    f_clear_pattern()
    pdir      := -1
    phase     := 1
    break_px  := close
    ext_px    := high
    phase_bar := bar_index
    big_a := line.new(h3b, h3, bar_index, res_now, color=color.new(col_bull, 10), width=2)
    float sup_anchor = l1 - avg_slope * (l1b - h3b)
    big_b := line.new(h3b, sup_anchor, bar_index, sup_anchor + avg_slope * (bar_index - h3b), color=color.new(col_bull, 10), width=2)
    f_add_lbl(label.new(bar_index, high, "① Суваг задарлаа", color=color.new(col_bull, 25), textcolor=color.white, style=label.style_label_down, size=size.small))

// ─── ② Impulse ───
if phase == 1
    if pdir == 1
        ext_px := math.min(ext_px, low)
        if bar_index - phase_bar > imp_wait or close > h1
            f_clear_pattern()
            pdir      := 0
            phase     := 0
            last_done := bar_index
        else if break_px - ext_px >= imp_min * atr_v
            phase     := 2
            phase_bar := bar_index
            sh1 := na
            sh2 := na
            sl1 := na
            sl2 := na
            f_add_lbl(label.new(bar_index, low, "② Хүчтэй уналт", color=color.new(col_bear, 35), textcolor=color.white, style=label.style_label_up, size=size.small))
    if pdir == -1
        ext_px := math.max(ext_px, high)
        if bar_index - phase_bar > imp_wait or close < l1
            f_clear_pattern()
            pdir      := 0
            phase     := 0
            last_done := bar_index
        else if ext_px - break_px >= imp_min * atr_v
            phase     := 2
            phase_bar := bar_index
            sh1 := na
            sh2 := na
            sl1 := na
            sl2 := na
            f_add_lbl(label.new(bar_index, high, "② Хүчтэй өсөлт", color=color.new(col_bull, 35), textcolor=color.white, style=label.style_label_down, size=size.small))

// ─── ③ Жижиг суваг ───
if phase == 2
    if bar_index - phase_bar > sml_wait
        f_clear_pattern()
        pdir      := 0
        phase     := 0
        last_done := bar_index
    if pdir == 1
        bool sml_asc = not na(sl1) and not na(sl2) and not na(sh1) and not na(sh2) and
             sl1 > sl2 and sh1 > sh2 and sl2b > phase_bar - sml_piv and sh2b > phase_bar - sml_piv
        if sml_asc
            phase     := 3
            sml_slope := (sl1 - sl2) / math.max(sl1b - sl2b, 1)
            sml_top   := math.max(sh1, sh2)
            phase_bar := bar_index
            sml_a := line.new(sl2b, sl2, bar_index + 12, sl1 + sml_slope * (bar_index + 12 - sl1b), color=color.new(col_bear, 25), width=1, style=line.style_dashed)
            float shs = (sh1 - sh2) / math.max(sh1b - sh2b, 1)
            sml_b := line.new(sh2b, sh2, bar_index + 12, sh1 + shs * (bar_index + 12 - sh1b), color=color.new(col_bear, 25), width=1, style=line.style_dashed)
            f_add_lbl(label.new(bar_index, high, "③ Жижиг суваг", color=color.new(col_bear, 45), textcolor=color.white, style=label.style_label_down, size=size.small))
    if pdir == -1
        bool sml_desc = not na(sh1) and not na(sh2) and not na(sl1) and not na(sl2) and
             sh1 < sh2 and sl1 < sl2 and sh2b > phase_bar - sml_piv and sl2b > phase_bar - sml_piv
        if sml_desc
            phase     := 3
            sml_slope := (sh1 - sh2) / math.max(sh1b - sh2b, 1)
            sml_bot   := math.min(sl1, sl2)
            phase_bar := bar_index
            sml_a := line.new(sh2b, sh2, bar_index + 12, sh1 + sml_slope * (bar_index + 12 - sh1b), color=color.new(col_bull, 25), width=1, style=line.style_dashed)
            float sls = (sl1 - sl2) / math.max(sl1b - sl2b, 1)
            sml_b := line.new(sl2b, sl2, bar_index + 12, sl1 + sls * (bar_index + 12 - sl1b), color=color.new(col_bull, 25), width=1, style=line.style_dashed)
            f_add_lbl(label.new(bar_index, low, "③ Жижиг суваг", color=color.new(col_bull, 45), textcolor=color.white, style=label.style_label_up, size=size.small))

// ─── ④ Жижиг суваг задрал → ENTRY ───
bool  sell_sig = false
bool  buy_sig  = false
float entry_p  = na
float sl_p     = na

if phase == 3
    if bar_index - phase_bar > sml_wait
        f_clear_pattern()
        pdir      := 0
        phase     := 0
        last_done := bar_index
    if pdir == 1
        float s_now = sl1 + sml_slope * (bar_index - sl1b)
        if not na(sph) and sph > sml_top
            sml_top := sph
        if close < s_now - bd_buf * atr_v and barstate.isconfirmed
            sell_sig  := true
            entry_p   := close
            sl_p      := sml_top + sl_buf * atr_v
            pdir      := 0
            phase     := 0
            last_done := bar_index
    if pdir == -1
        float r_now = sh1 + sml_slope * (bar_index - sh1b)
        if not na(spl) and spl < sml_bot
            sml_bot := spl
        if close > r_now + bd_buf * atr_v and barstate.isconfirmed
            buy_sig   := true
            entry_p   := close
            sl_p      := sml_bot - sl_buf * atr_v
            pdir      := 0
            phase     := 0
            last_done := bar_index

// ─── TP + бүс ───
float risk_v = sell_sig ? sl_p - entry_p : buy_sig ? entry_p - sl_p : na
float tp1_v  = sell_sig ? entry_p - risk_v * rr1 : buy_sig ? entry_p + risk_v * rr1 : na
float tp2_v  = sell_sig ? entry_p - risk_v * rr2 : buy_sig ? entry_p + risk_v * rr2 : na

var box   stop_bx = na
var box   prof_bx = na
var label e_lb    = na
var label s_lb    = na
var label t_lb    = na

if (sell_sig or buy_sig) and risk_v > 0
    box.delete(stop_bx)
    box.delete(prof_bx)
    label.delete(e_lb)
    label.delete(s_lb)
    label.delete(t_lb)
    int r = bar_index + 35
    stop_bx := box.new(bar_index, math.max(entry_p, sl_p), r, math.min(entry_p, sl_p), border_color=color.new(color.blue, 60), bgcolor=color.new(color.rgb(120,140,220), 65))
    prof_bx := box.new(bar_index, math.max(entry_p, tp2_v), r, math.min(entry_p, tp2_v), border_color=color.new(color.teal, 60), bgcolor=color.new(color.rgb(60,200,180), 70))
    e_lb := label.new(r, entry_p, "ENTRY " + str.tostring(entry_p, format.mintick), color=color.new(color.gray, 60), textcolor=color.white, style=label.style_label_left, size=size.small)
    s_lb := label.new(r, sl_p,    "STOP "  + str.tostring(sl_p,    format.mintick), color=color.new(color.blue, 60), textcolor=color.white, style=label.style_label_left, size=size.small)
    t_lb := label.new(r, tp2_v,   "TP2 "   + str.tostring(tp2_v,   format.mintick), color=color.new(color.teal, 60), textcolor=color.white, style=label.style_label_left, size=size.small)

plotshape(sell_sig, "AAD SELL", shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60),  0), textcolor=color.white, text="SELL\nAAD", size=size.normal)
plotshape(buy_sig,  "AAD BUY",  shape.labelup,   location.belowbar, color.new(color.rgb(38,200,120), 0), textcolor=color.white, text="BUY\nAAD", size=size.normal)

// ─── Winrate Tracking ───
var int   trade_dir = 0
var float trade_sl  = na
var float trade_tp1 = na
var float trade_tp2 = na
var int   wins      = 0
var int   losses    = 0
var int   tp2_hits  = 0
var bool  tp1_done  = false

if sell_sig and risk_v > 0
    trade_dir := -1
    trade_sl  := sl_p
    trade_tp1 := tp1_v
    trade_tp2 := tp2_v
    tp1_done  := false
if buy_sig and risk_v > 0
    trade_dir := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_v
    trade_tp2 := tp2_v
    tp1_done  := false

if trade_dir == -1 and not (sell_sig or buy_sig)
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

if trade_dir == 1 and not (sell_sig or buy_sig)
    if not tp1_done and high >= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and high >= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if low <= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 5, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string dir_s = pdir == 1 ? "SELL" : pdir == -1 ? "BUY" : ""
    string st_txt = phase == 1 ? "① Задарсан (" + dir_s + ") — impulse хүлээж" :
         phase == 2 ? "② Impulse ✓ (" + dir_s + ") — жижиг суваг хүлээж" :
         phase == 3 ? "③ Жижиг суваг (" + dir_s + ") — задрал хүлээж" :
         trade_dir != 0 ? (trade_dir == 1 ? "📈 LONG нээлттэй" : "📉 SHORT нээлттэй") : "○ Том параллель суваг хайж"
    color  st_col = pdir == 1 ? col_bear : pdir == -1 ? col_bull : color.rgb(160,175,220)
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? col_bull : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    table.cell(dash, 0, 0, " AAD v4 📐", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Үе шат",  bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, st_txt,     bgcolor=color.rgb(14,17,28), text_color=st_col, text_size=size.small)
    table.cell(dash, 0, 2, " Winrate", bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, wr_txt,     bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 3, " Арилжаа", bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits), bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 4, " ATR",     bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(atr_v, format.mintick), bgcolor=color.rgb(10,10,18), text_color=color.rgb(160,175,220), text_size=size.small)

// ─── Alerts ───
alertcondition(sell_sig, "AAD v4 SELL", "AAD v4 SELL — {{ticker}} @ {{close}}")
alertcondition(buy_sig,  "AAD v4 BUY",  "AAD v4 BUY — {{ticker}} @ {{close}}")
alertcondition(phase == 3 and phase[1] == 2, "AAD ③ Жижиг суваг", "AAD v4: жижиг суваг үүслээ — {{ticker}}")
