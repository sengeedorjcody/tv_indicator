//@version=6
indicator("AAD Pattern v1 — Bearish Channel Breakdown", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
//  AAD PATTERN v1 (SELL only)
//
//  Бүтэц: DOWNTREND дотор өсөх засварын суваг (bearish pattern) —
//  HH/HL дараалан өсөж urged боловч энэ нь зөвхөн correction.
//
//   DOWN TREND
//   \        HH
//    \    HH /\  ____ resistance
//     \ HH/\/  \/
//      \/\/ HL/\   LH ← жижиг pullback
//       /\/HL   \  /\___
//      /HL ____  \/  \ ↓ ENTRY (3)
//     /   support \   \
//                  \(1)breakdown
//                   (2) last HL эвдэрсэн
//
//  3 ДҮРЭМ (TradingView идеяны дагуу):
//   ① Үнэ том bearish pattern-ийн SUPPORT ШУГАМААС доош гарна
//      (өсөх HL-үүдийг холбосон trendline эвдэрнэ)
//   ② Үнэ сүүлийн HL ТҮВШНИЙГ нэвтэлнэ (бүтэц бүрэн эвдэрсэн)
//   ③ Жижиг pullback (LH) үүсч, тэр жижиг pattern ЭВДРЭХЭД ENTRY
//      SL = LH дээр, TP = R:R
//
//  Яагаад ажилладаг: Downtrend доторх өсөх суваг = зах зээл
//  liquidity цуглуулж буй correction. Суваг эвдрэх нь үндсэн
//  trend үргэлжлэхийн дохио — гурван шатны баталгаатай оролт.
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_CH   = "① Суваг (bearish pattern)"
string G_BD   = "② Breakdown"
string G_ENT  = "③ Entry / Risk"
string G_VIS  = "④ Visual"

// ─── Channel Inputs ───
int   piv_len   = input.int(4,  "Pivot Length", minval=2, maxval=10, group=G_CH)
float ch_min_up = input.float(0.1, "HL/HH min өсөлт (ATR×)", minval=0.0, step=0.05, group=G_CH,
     tooltip="Дараалсан HL болон HH бүр өмнөхөөсөө энэ хэмжээгээр өндөр байх — жинхэнэ өсөх суваг")
bool  use_dt    = input.bool(true, "Downtrend контекст шаардах", group=G_CH,
     tooltip="Суваг үүсэхээс өмнө үнэ буурсан байх (EMA200 доор эсвэл EMA урууд) — зөвхөн correction-ий суваг")
int   dt_ema    = input.int(200, "Downtrend EMA", minval=50, group=G_CH)

// ─── Breakdown Inputs ───
float bd_buf    = input.float(0.1, "Breakdown buffer (ATR×)", minval=0.0, step=0.05, group=G_BD)
int   max_wait  = input.int(60, "Үе шат бүрийн max хугацаа (bars)", minval=20, maxval=200, group=G_BD)

// ─── Entry Inputs ───
int   mini_piv  = input.int(2,  "Жижиг LH pivot length", minval=1, maxval=5, group=G_ENT,
     tooltip="Pullback-ийн LH оргилыг таних жижиг pivot")
float min_pull  = input.float(0.5, "Pullback min өндөр (ATR×)", minval=0.1, step=0.1, group=G_ENT,
     tooltip="Breakdown доод цэгээс дээшээ энэ хэмжээгээр эргэсэн байх — жинхэнэ pullback")
int   atr_len   = input.int(14,    "ATR Length", minval=1, group=G_ENT)
float sl_buf    = input.float(0.3, "SL buffer LH-ээс (ATR×)", minval=0.0, step=0.1, group=G_ENT)
float rr1       = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_ENT)
float rr2       = input.float(2.0, "TP2 R:R", minval=1.0, step=0.5, group=G_ENT)

// ─── Visual ───
color col_bear   = input.color(color.rgb(240, 80, 60), "Bear өнгө", group=G_VIS)
bool  show_ch    = input.bool(true, "Суваг шугам зурах", group=G_VIS)
bool  show_dash  = input.bool(true, "Dashboard", group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

float atr_v = ta.atr(atr_len)
float ema_v = ta.ema(close, dt_ema)
bool  dt_ok = not use_dt or close < ema_v or ema_v < ema_v[10]

// ─── Pivot tracking ───
float ph = ta.pivothigh(high, piv_len, piv_len)
float pl = ta.pivotlow(low,   piv_len, piv_len)

var float hh1 = na
var float hh2 = na
var int   hh1_bar = na
var int   hh2_bar = na
var float hl1 = na
var float hl2 = na
var int   hl1_bar = na
var int   hl2_bar = na

if not na(ph)
    hh2     := hh1
    hh2_bar := hh1_bar
    hh1     := ph
    hh1_bar := bar_index - piv_len
if not na(pl)
    hl2     := hl1
    hl2_bar := hl1_bar
    hl1     := pl
    hl1_bar := bar_index - piv_len

// ─── Өсөх суваг: HL өсөж + HH өсөж ───
bool rising_hl = not na(hl1) and not na(hl2) and hl1 > hl2 + ch_min_up * atr_v
bool rising_hh = not na(hh1) and not na(hh2) and hh1 > hh2 + ch_min_up * atr_v
bool channel_ok = rising_hl and rising_hh and dt_ok

// Support шугам: hl2 → hl1 цэгүүдийг холбосон шулуун (projection)
float slope = channel_ok and hl1_bar != hl2_bar ? (hl1 - hl2) / (hl1_bar - hl2_bar) : na
float support_now = channel_ok and not na(slope) ? hl1 + slope * (bar_index - hl1_bar) : na

// ═══════════════════════════════════════════════════════════════════
// STATE MACHINE
//  0 = суваг хайж | 1 = ① support эвдэрсэн | 2 = ② last HL эвдэрсэн
//  (3 = ③ LH үүссэн → entry шалгана)
// ═══════════════════════════════════════════════════════════════════

var int   phase      = 0
var float last_hl    = na    // ②-д эвдэх ёстой HL түвшин
var float bd_low     = na    // breakdown-ий доод цэг
var float mini_lh    = na    // жижиг pullback-ийн LH
var float mini_low   = na    // жижиг pattern-ийн доод цэг (entry trigger)
var int   phase_bar  = na
var int   used_ch_bar = na   // one-shot: ашигласан сувгийн hl1_bar
var line  sup_ln     = na
var line  hl_ln      = na

// ─── ① Support шугам эвдрэх ───
bool support_break = channel_ok and not na(support_now) and
     close < support_now - bd_buf * atr_v and phase == 0 and
     (na(used_ch_bar) or hl1_bar != used_ch_bar)

if support_break
    phase     := 1
    last_hl   := hl1
    bd_low    := low
    phase_bar := bar_index
    if show_ch
        line.delete(sup_ln)
        sup_ln := line.new(hl2_bar, hl2, bar_index, support_now, color=color.new(col_bear, 30), width=2, style=line.style_dashed)
        label.new(bar_index, low, "① Support эвдэрлээ", color=color.new(col_bear, 40), textcolor=color.white, style=label.style_label_up, size=size.small)
        line.delete(hl_ln)
        hl_ln := line.new(bar_index, hl1, bar_index + max_wait, hl1, color=color.new(color.orange, 40), width=1, style=line.style_dotted)

// ─── ② Last HL түвшин эвдрэх ───
if phase == 1
    bd_low := math.min(bd_low, low)
    if bar_index - phase_bar > max_wait or close > hh1   // цуцлах: хугацаа эсвэл шинэ HH
        phase := 0
        line.delete(sup_ln)
        line.delete(hl_ln)
    else if close < last_hl - bd_buf * atr_v
        phase     := 2
        bd_low    := low
        mini_lh   := na
        phase_bar := bar_index
        label.new(bar_index, low, "② HL эвдэрлээ", color=color.new(col_bear, 30), textcolor=color.white, style=label.style_label_up, size=size.small)

// ─── ③ Жижиг pullback (LH) + entry ───
float mini_ph = ta.pivothigh(high, mini_piv, mini_piv)

bool  short_entry = false
float entry_p     = na
float sl_p        = na

if phase == 2
    bd_low := math.min(bd_low, low)
    // Цуцлах: хугацаа хэтэрсэн эсвэл last HL-ээс дээш буцсан (fake breakdown)
    if bar_index - phase_bar > max_wait or close > last_hl
        phase := 0
        line.delete(sup_ln)
        line.delete(hl_ln)
    else
        // LH тэмдэглэх: жижиг pivot high, bd_low-оос дээш хангалттай эргэсэн, last HL-ээс доор
        if not na(mini_ph) and mini_ph > bd_low + min_pull * atr_v and mini_ph < last_hl
            mini_lh  := mini_ph
            mini_low := bd_low
            label.new(bar_index - mini_piv, mini_ph, "LH", color=color.new(col_bear, 50), textcolor=color.white, style=label.style_label_down, size=size.small)
        // ③ ENTRY: LH үүссэн + үнэ жижиг pattern-ийн доод цэгийг эвдэв
        if not na(mini_lh) and close < mini_low - bd_buf * atr_v and barstate.isconfirmed
            short_entry := true
            entry_p     := close
            sl_p        := mini_lh + sl_buf * atr_v
            phase       := 0
            used_ch_bar := hl1_bar
            line.delete(sup_ln)
            line.delete(hl_ln)

// ─── TP ───
float risk_s = short_entry ? sl_p - entry_p : na
float tp1_s  = short_entry ? entry_p - risk_s * rr1 : na
float tp2_s  = short_entry ? entry_p - risk_s * rr2 : na

// ─── Drawing ───
var line  e_ln  = na
var line  sl_ln = na
var line  t1_ln = na
var line  t2_ln = na
var label e_lb  = na
var label sl_lb = na
var label t1_lb = na
var label t2_lb = na

if short_entry and risk_s > 0
    line.delete(e_ln)
    line.delete(sl_ln)
    line.delete(t1_ln)
    line.delete(t2_ln)
    label.delete(e_lb)
    label.delete(sl_lb)
    label.delete(t1_lb)
    label.delete(t2_lb)
    int r = bar_index + 30
    e_ln  := line.new(bar_index, entry_p, r, entry_p, color=col_bear,    width=2)
    sl_ln := line.new(bar_index, sl_p,    r, sl_p,    color=color.red,   width=1, style=line.style_dashed)
    t1_ln := line.new(bar_index, tp1_s,   r, tp1_s,   color=color.green, width=1, style=line.style_dashed)
    t2_ln := line.new(bar_index, tp2_s,   r, tp2_s,   color=color.new(color.green, 40), width=1, style=line.style_dotted)
    e_lb  := label.new(r, entry_p, "Entry " + str.tostring(entry_p, format.mintick), color=color.new(col_bear, 75),   textcolor=color.white, style=label.style_label_left, size=size.small)
    sl_lb := label.new(r, sl_p,    "SL "    + str.tostring(sl_p,    format.mintick), color=color.new(color.red, 75),  textcolor=color.white, style=label.style_label_left, size=size.small)
    t1_lb := label.new(r, tp1_s,   "TP1 "   + str.tostring(tp1_s,   format.mintick), color=color.new(color.green,75), textcolor=color.white, style=label.style_label_left, size=size.small)
    t2_lb := label.new(r, tp2_s,   "TP2 "   + str.tostring(tp2_s,   format.mintick), color=color.new(color.green,85), textcolor=color.white, style=label.style_label_left, size=size.small)

// ─── Signal label ───
plotshape(short_entry, "AAD SELL", shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60), 0), textcolor=color.white, text="SELL\nAAD③", size=size.normal)

// ─── Winrate Tracking (TP1 = WIN + breakeven) ───
var int   trade_on   = 0
var float trade_sl   = na
var float trade_tp1  = na
var float trade_tp2  = na
var int   wins       = 0
var int   losses     = 0
var int   tp2_hits   = 0
var bool  tp1_done   = false

if short_entry and risk_s > 0
    trade_on  := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_s
    trade_tp2 := tp2_s
    tp1_done  := false

if trade_on == 1 and not short_entry
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits := tp2_hits + 1
        trade_on := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_on := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 7, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string st_txt = phase == 1 ? "① Support эвдэрсэн — HL хүлээж" : phase == 2 ? (na(mini_lh) ? "② HL эвдэрсэн — LH хүлээж" : "③ LH бэлэн — breakdown хүлээж") : trade_on != 0 ? "📉 SHORT нээлттэй" : "○ Өсөх суваг хайж (downtrend-д)"
    color  st_col = phase != 0 ? col_bear : color.rgb(160,175,220)
    string hl_txt = phase != 0 ? str.tostring(last_hl, format.mintick) : "—"
    string lh_txt = phase == 2 and not na(mini_lh) ? str.tostring(mini_lh, format.mintick) : "—"
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? color.rgb(38,200,120) : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    string tt_txt = str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits)
    table.cell(dash, 0, 0, " AAD Pattern 📐", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Үе шат",     bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, st_txt,        bgcolor=color.rgb(14,17,28), text_color=st_col, text_size=size.small)
    table.cell(dash, 0, 2, " Last HL ②",  bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, hl_txt,        bgcolor=color.rgb(10,10,18), text_color=color.rgb(255,200,0), text_size=size.small)
    table.cell(dash, 0, 3, " LH (SL) ③",  bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, lh_txt,        bgcolor=color.rgb(14,17,28), text_color=color.rgb(220,40,80), text_size=size.small)
    table.cell(dash, 0, 4, " Winrate",    bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, wr_txt,        bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 5, " Арилжаа",    bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 5, tt_txt,        bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 6, " Downtrend",  bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 6, dt_ok ? "✅" : "❌ (суваг тоохгүй)", bgcolor=color.rgb(10,10,18), text_color=dt_ok ? color.rgb(38,200,120) : color.gray, text_size=size.small)

// ─── Alerts ───
alertcondition(short_entry, "AAD SELL", "AAD pattern SELL — {{ticker}} @ {{close}}")
alertcondition(phase == 1 and phase[1] == 0, "AAD ① Support эвдэрлээ", "AAD: суваг support эвдэрлээ — {{ticker}}")
alertcondition(phase == 2 and phase[1] == 1, "AAD ② HL эвдэрлээ", "AAD: last HL эвдэрлээ — {{ticker}}, LH pullback хүлээж байна")
