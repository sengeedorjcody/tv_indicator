//@version=6
indicator("Flag Pattern v1 — Bull/Bear Flag Breakout", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
//  FLAG PATTERN v1 — BULL & BEAR FLAG
//
//  BULL FLAG:                      BEAR FLAG:
//       breakout → BUY                 ▔▔\
//      ▲    ____                        \ \____
//     / \  /💪 /  ← flag                 \ 🚩 /\___
//    /   \/___/    (жижиг буцалт)         \▔▔▔\    ← flag
//   /  шон (pole)                          \ шон   \
//  /   хүчтэй өсөлт                         \       ▼ breakout → SELL
//
//  3 үе шат:
//   ① POLE (шон) — богино хугацаанд ХҮЧТЭЙ нэг чиглэлийн хөдөлгөөн
//   ② FLAG (туг)  — жижиг, ЭСРЭГ чиглэлийн нам гүм амралт
//       · retrace нь шонгийн 20-50%-аас хэтрэхгүй
//       · volatility агшсан (нарийн зурвас)
//   ③ BREAKOUT   — flag-ийн хилийг эвдэхэд ENTRY
//       · SL = flag-ийн нөгөө тал
//       · TP1 = 1R, TP2 = measured move (шонгийн өндөр)
//
//  Яагаад өндөр winrate: Institutional continuation загвар —
//  хүчтэй хөдөлгөөний дараах амралт нь ихэвчлэн үргэлжилдэг.
//  Trend-ийн эсрэг биш, trend-ийн ДАГУУ ордог.
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_POLE = "① Pole (шон)"
string G_FLAG = "② Flag (туг)"
string G_ENT  = "③ Entry / Risk"
string G_VIS  = "④ Visual"

// ─── Pole Inputs ───
int   pole_len  = input.int(12,   "Pole хайх цонх (bars)", minval=5, maxval=40, group=G_POLE)
float pole_min  = input.float(2.5,"Pole min өндөр (ATR×)", minval=1.0, step=0.25, group=G_POLE,
     tooltip="Энэ цонхонд үнэ ATR×энэ хэмжээгээр нэг чиглэлд хөдөлсөн байх — хүчтэй impulse")
float pole_dir  = input.float(0.65,"Pole чиглэлийн цэвэр байдал", minval=0.5, maxval=0.95, step=0.05, group=G_POLE,
     tooltip="Pole доторх лааны энэ хувь нь нэг чиглэлд байх (0.65 = 65% нь өсөх лаа bull pole-д)")

// ─── Flag Inputs ───
int   flag_min  = input.int(4,    "Flag min урт (bars)", minval=2, maxval=20, group=G_FLAG)
int   flag_max  = input.int(25,   "Flag max урт (bars)", minval=5, maxval=60, group=G_FLAG)
float retr_max  = input.float(0.5,"Max retrace (шонгийн %)", minval=0.2, maxval=0.7, step=0.05, group=G_FLAG,
     tooltip="Flag нь шонгийн энэ хувиас илүү буцвал pattern хүчингүй (0.5 = 50%)")
bool  use_vol   = input.bool(true,"Volume шүүлтүүр", group=G_FLAG,
     tooltip="Flag доторх volume нь pole-ийн volume-ээс бага байх (сонгодог flag шинж)")

// ─── Entry / Risk ───
float bo_buf    = input.float(0.1, "Breakout buffer (ATR×)", minval=0.0, step=0.05, group=G_ENT,
     tooltip="Flag хилээс энэ хэмжээгээр давж хаагдахад entry")
int   atr_len   = input.int(14,    "ATR Length", minval=1, group=G_ENT)
float sl_buf    = input.float(0.3, "SL buffer (ATR×)", minval=0.0, step=0.1, group=G_ENT)
float rr1       = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_ENT)
bool  tp2_mm    = input.bool(true, "TP2 = Measured Move (шонгийн өндөр)", group=G_ENT,
     tooltip="Унтраавал TP2 = 2R")
float rr2       = input.float(2.0, "TP2 R:R (MM унтраасан үед)", minval=1.0, step=0.5, group=G_ENT)
bool  use_htf   = input.bool(false, "HTF EMA шүүлтүүр", group=G_ENT)
string htf_tf   = input.timeframe("60", "HTF Timeframe", group=G_ENT)
int   htf_len   = input.int(50, "HTF EMA Length", minval=1, group=G_ENT)

// ─── Visual ───
color col_bull = input.color(color.rgb(38, 200, 120), "Bull", group=G_VIS)
color col_bear = input.color(color.rgb(240, 80, 60),  "Bear", group=G_VIS)
bool  show_flag = input.bool(true, "Flag бүс зурах", group=G_VIS)
bool  show_dash = input.bool(true, "Dashboard", group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

float atr_v   = ta.atr(atr_len)
float htf_ema = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_len), lookahead=barmerge.lookahead_off)
bool  f_htf_l = not use_htf or close > htf_ema
bool  f_htf_s = not use_htf or close < htf_ema
float vol_sma = ta.sma(volume, 20)

// ─── ① POLE Detection ───
// Bull pole: pole_len bar-д үнэ pole_min ATR-аар өссөн + ихэнх лаа ногоон
float chg = close - close[pole_len]
int   up_candles = 0
int   dn_candles = 0
for i = 0 to pole_len - 1
    if close[i] > open[i]
        up_candles += 1
    if close[i] < open[i]
        dn_candles += 1

float up_ratio = up_candles / float(pole_len)
float dn_ratio = dn_candles / float(pole_len)

bool bull_pole_now = chg >= pole_min * atr_v and up_ratio >= pole_dir
bool bear_pole_now = -chg >= pole_min * atr_v and dn_ratio >= pole_dir

// ═══════════════════════════════════════════════════════════════════
// STATE MACHINE
//  0 = pole хайж | 1 = bull flag үүсч байна | -1 = bear flag үүсч байна
// ═══════════════════════════════════════════════════════════════════

var int   fstate     = 0
var float pole_top   = na    // bull: шонгийн орой, bear: шонгийн ёроол
var float pole_bot   = na    // шонгийн эхлэл
var float pole_h     = na    // шонгийн өндөр (measured move-д)
var int   flag_start = na
var float flag_hi    = na    // flag доторх дээд цэг
var float flag_lo    = na    // flag доторх доод цэг
var float pole_vol   = na    // pole үеийн дундаж volume
var box   flag_box   = na

// ─── Bull pole илэрлээ → flag хүлээх ───
if bull_pole_now and fstate == 0
    fstate     := 1
    pole_top   := high
    pole_bot   := close[pole_len]
    pole_h     := high - close[pole_len]
    flag_start := bar_index
    flag_hi    := high
    flag_lo    := low
    pole_vol   := ta.sma(volume, pole_len)

// ─── Bear pole илэрлээ → flag хүлээх ───
if bear_pole_now and fstate == 0
    fstate     := -1
    pole_top   := close[pole_len]
    pole_bot   := low
    pole_h     := close[pole_len] - low
    flag_start := bar_index
    flag_hi    := high
    flag_lo    := low
    pole_vol   := ta.sma(volume, pole_len)

// ═══════════════════════════════════════════════════════════════════
// ② FLAG FORMATION + ③ BREAKOUT
// ═══════════════════════════════════════════════════════════════════

bool long_entry  = false
bool short_entry = false
float entry_p    = na
float sl_p       = na
float tp1_v      = na
float tp2_v      = na

// ─── BULL FLAG ───
if fstate == 1 and bar_index > flag_start
    // Flag хил шинэчлэх
    flag_hi := math.max(flag_hi, high)
    flag_lo := math.min(flag_lo, low)
    int flag_len = bar_index - flag_start

    // Хүчингүй болох нөхцөлүүд:
    // 1. Retrace хэт гүн (шонгийн retr_max%-аас их унасан)
    // 2. Flag хэт удаан үргэлжилсэн
    bool too_deep = flag_lo < pole_top - pole_h * retr_max
    bool too_long = flag_len > flag_max
    if too_deep or too_long
        fstate := 0
        box.delete(flag_box)
    else
        // Flag box зурах
        if show_flag
            if na(flag_box)
                flag_box := box.new(flag_start, flag_hi, bar_index, flag_lo, border_color=color.new(col_bull, 50), bgcolor=color.new(col_bull, 90))
            else
                box.set_right(flag_box, bar_index)
                box.set_top(flag_box, flag_hi)
                box.set_bottom(flag_box, flag_lo)

        // Volume шалгалт: flag volume < pole volume
        bool vol_ok = not use_vol or ta.sma(volume, math.max(flag_len, 1)) < pole_vol

        // BREAKOUT: flag min урт хангасан + close нь pole_top-оос дээш
        if flag_len >= flag_min and close > pole_top + bo_buf * atr_v and vol_ok and f_htf_l and barstate.isconfirmed
            long_entry := true
            entry_p    := close
            sl_p       := flag_lo - sl_buf * atr_v
            float risk = entry_p - sl_p
            tp1_v      := entry_p + risk * rr1
            tp2_v      := tp2_mm ? entry_p + pole_h : entry_p + risk * rr2
            fstate     := 0
            box.delete(flag_box)

// ─── BEAR FLAG ───
if fstate == -1 and bar_index > flag_start
    flag_hi := math.max(flag_hi, high)
    flag_lo := math.min(flag_lo, low)
    int flag_len = bar_index - flag_start

    bool too_deep = flag_hi > pole_bot + pole_h * retr_max
    bool too_long = flag_len > flag_max
    if too_deep or too_long
        fstate := 0
        box.delete(flag_box)
    else
        if show_flag
            if na(flag_box)
                flag_box := box.new(flag_start, flag_hi, bar_index, flag_lo, border_color=color.new(col_bear, 50), bgcolor=color.new(col_bear, 90))
            else
                box.set_right(flag_box, bar_index)
                box.set_top(flag_box, flag_hi)
                box.set_bottom(flag_box, flag_lo)

        bool vol_ok = not use_vol or ta.sma(volume, math.max(flag_len, 1)) < pole_vol

        // BREAKOUT: close нь pole_bot-оос доош
        if flag_len >= flag_min and close < pole_bot - bo_buf * atr_v and vol_ok and f_htf_s and barstate.isconfirmed
            short_entry := true
            entry_p     := close
            sl_p        := flag_hi + sl_buf * atr_v
            float risk  = sl_p - entry_p
            tp1_v       := entry_p - risk * rr1
            tp2_v       := tp2_mm ? entry_p - pole_h : entry_p - risk * rr2
            fstate      := 0
            box.delete(flag_box)

// ─── Drawing ───
var line  e_ln  = na
var line  sl_ln = na
var line  t1_ln = na
var line  t2_ln = na
var label e_lb  = na
var label sl_lb = na
var label t1_lb = na
var label t2_lb = na

f_draw(float ep, float sp, float t1, float t2, color c) =>
    line.delete(e_ln)
    line.delete(sl_ln)
    line.delete(t1_ln)
    line.delete(t2_ln)
    label.delete(e_lb)
    label.delete(sl_lb)
    label.delete(t1_lb)
    label.delete(t2_lb)
    int r = bar_index + 30
    e  = line.new(bar_index, ep, r, ep, color=c,           width=2)
    s  = line.new(bar_index, sp, r, sp, color=color.red,   width=1, style=line.style_dashed)
    a  = line.new(bar_index, t1, r, t1, color=color.green, width=1, style=line.style_dashed)
    b  = line.new(bar_index, t2, r, t2, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    el = label.new(r, ep, "Entry " + str.tostring(ep, format.mintick), color=color.new(c, 75),          textcolor=color.white, style=label.style_label_left, size=size.small)
    sl = label.new(r, sp, "SL "    + str.tostring(sp, format.mintick), color=color.new(color.red, 75),  textcolor=color.white, style=label.style_label_left, size=size.small)
    l1 = label.new(r, t1, "TP1 "   + str.tostring(t1, format.mintick), color=color.new(color.green,75), textcolor=color.white, style=label.style_label_left, size=size.small)
    l2 = label.new(r, t2, "TP2 "   + str.tostring(t2, format.mintick), color=color.new(color.green,85), textcolor=color.white, style=label.style_label_left, size=size.small)
    [e, s, a, b, el, sl, l1, l2]

if long_entry
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_v, tp2_v, col_bull)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

if short_entry
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_v, tp2_v, col_bear)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

// ─── Signal labels ───
plotshape(long_entry,  "BULL FLAG",  shape.labelup,   location.belowbar, color.new(color.rgb(38,200,120), 0), textcolor=color.white, text="BUY\n🚩", size=size.normal)
plotshape(short_entry, "BEAR FLAG",  shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60),  0), textcolor=color.white, text="SELL\n🚩", size=size.normal)

// ─── Winrate Tracking (TP1 = WIN + breakeven) ───
var int   trade_dir  = 0
var float trade_sl   = na
var float trade_tp1  = na
var float trade_tp2  = na
var int   wins       = 0
var int   losses     = 0
var int   tp2_hits   = 0
var bool  tp1_done   = false

if long_entry
    trade_dir := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_v
    trade_tp2 := tp2_v
    tp1_done  := false
if short_entry
    trade_dir := -1
    trade_sl  := sl_p
    trade_tp1 := tp1_v
    trade_tp2 := tp2_v
    tp1_done  := false

if trade_dir == 1 and not (long_entry or short_entry)
    if not tp1_done and high >= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and high >= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if low <= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

if trade_dir == -1 and not (long_entry or short_entry)
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 7, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string st_txt = fstate == 1 ? "🚩 Bull Flag үүсч байна" : fstate == -1 ? "🚩 Bear Flag үүсч байна" : trade_dir != 0 ? (trade_dir == 1 ? "📈 LONG нээлттэй" : "📉 SHORT нээлттэй") : "○ Pole хайж байна"
    color  st_col = fstate == 1 ? col_bull : fstate == -1 ? col_bear : color.rgb(160,175,220)
    string po_txt = fstate != 0 ? str.tostring(pole_h, format.mintick) + " (" + str.tostring(pole_h / atr_v, "#.#") + " ATR)" : "—"
    string bo_txt = fstate == 1 ? str.tostring(pole_top + bo_buf * atr_v, format.mintick) : fstate == -1 ? str.tostring(pole_bot - bo_buf * atr_v, format.mintick) : "—"
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? col_bull : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    string tt_txt = str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits)
    table.cell(dash, 0, 0, " Flag Pattern 🚩", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Төлөв",       bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, st_txt,         bgcolor=color.rgb(14,17,28), text_color=st_col, text_size=size.small)
    table.cell(dash, 0, 2, " Pole өндөр",  bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, po_txt,         bgcolor=color.rgb(10,10,18), text_color=color.rgb(255,200,0), text_size=size.small)
    table.cell(dash, 0, 3, " Breakout @",  bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, bo_txt,         bgcolor=color.rgb(14,17,28), text_color=color.rgb(0,200,255), text_size=size.small)
    table.cell(dash, 0, 4, " Winrate",     bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, wr_txt,         bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 5, " Арилжаа",     bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 5, tt_txt,         bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 6, " ATR",         bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(atr_v, format.mintick), bgcolor=color.rgb(10,10,18), text_color=color.rgb(160,175,220), text_size=size.small)

// ─── Alerts ───
alertcondition(long_entry,  "Bull Flag BUY",   "Bull Flag breakout BUY — {{ticker}} @ {{close}}")
alertcondition(short_entry, "Bear Flag SELL",  "Bear Flag breakout SELL — {{ticker}} @ {{close}}")
alertcondition(fstate != 0 and fstate[1] == 0, "Flag үүсч эхэллээ", "Flag pattern үүсч байна — {{ticker}}, breakout хүлээнэ")
