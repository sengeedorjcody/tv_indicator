//@version=5
// Overlay indicator — must appear on the main price chart by default
indicator("Inducement SMC Entry — Overlay", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ═════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═════════════════════════════════════════════════════════════════════════════
groupDisplay = "Display Settings"
showOnlyEntries= input.bool(false, "Show Only Entry Signals", group=groupDisplay)
showSwings     = input.bool(true, "Show Swing Highs/Lows", group=groupDisplay)
showBosChoch   = input.bool(true, "Show BOS / CHoCH", group=groupDisplay)
showInduceLbl  = input.bool(true, "Show Inducement Labels", group=groupDisplay)
showTargets    = input.bool(true, "Show TP / SL", group=groupDisplay)
showDebug      = input.bool(false, "Show Debug Info (why signal blocked)", group=groupDisplay)

groupSettings = "Swing / Structure Settings"
swingLen      = input.int(5, "Swing Lookback", minval=1, group=groupSettings)
induceSwingLen= input.int(3, "Inducement Swing Lookback", minval=1, group=groupSettings)

groupInduce = "Inducement Settings"
useInducement = input.bool(true, "Detect Inducement", group=groupInduce)

groupEntry = "Entry Settings"
filterMode    = input.string("None", "Signal Filter Mode", options=["None", "FVG only", "OB only", "FVG + OB"], group=groupEntry)
fvgThreshold  = input.float(0.0, "Min FVG Size (pips)", minval=0.0, step=0.1, group=groupEntry)
obLookback    = input.int(5, "Order Block Lookback", minval=1, group=groupEntry)
riskReward    = input.float(2.0, "Risk:Reward", minval=0.1, step=0.1, group=groupEntry)
atrPeriod     = input.int(14, "ATR Period for SL", group=groupEntry)
atrMult       = input.float(1.5, "ATR Multiplier", minval=0.1, step=0.1, group=groupEntry)

groupWinrate = "Winrate Stats"
showWinrate   = input.bool(true, "Show Winrate Statistics", group=groupWinrate)
maxSignals    = input.int(200, "Max Signals to Track", minval=10, group=groupWinrate)

// ═════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═════════════════════════════════════════════════════════════════════════════
pipFactor = syminfo.mintick * 10
atr = ta.atr(atrPeriod)

useFvg = filterMode == "FVG only" or filterMode == "FVG + OB"
useOb  = filterMode == "OB only" or filterMode == "FVG + OB"

// ═════════════════════════════════════════════════════════════════════════════
// SWING POINTS
// ═════════════════════════════════════════════════════════════════════════════
var float lastSwingHigh    = na
var float lastSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

if not na(swingHigh)
    lastSwingHigh    := swingHigh
    lastSwingHighBar := bar_index[swingLen]
if not na(swingLow)
    lastSwingLow    := swingLow
    lastSwingLowBar := bar_index[swingLen]

plotshape(not showOnlyEntries and showSwings and not na(swingHigh), title="Swing High", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, offset=-swingLen)
plotshape(not showOnlyEntries and showSwings and not na(swingLow), title="Swing Low", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, offset=-swingLen)

// ═════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE (BOS / CHoCH)
// ═════════════════════════════════════════════════════════════════════════════
var string marketStructure = "neutral"

bullishBos  = close > lastSwingHigh and marketStructure != "bullish"
bearishBos  = close < lastSwingLow  and marketStructure != "bearish"
bullishChoch = close > lastSwingHigh and marketStructure == "bearish"
bearishChoch = close < lastSwingLow  and marketStructure == "bullish"

if bullishBos or bullishChoch
    marketStructure := "bullish"
    if not showOnlyEntries and showBosChoch
        line.new(lastSwingHighBar, lastSwingHigh, bar_index, lastSwingHigh, color=color.green, style=line.style_solid, width=2)
        label.new(bar_index, lastSwingHigh, bullishChoch ? "CHoCH" : "BOS", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

if bearishBos or bearishChoch
    marketStructure := "bearish"
    if not showOnlyEntries and showBosChoch
        line.new(lastSwingLowBar, lastSwingLow, bar_index, lastSwingLow, color=color.red, style=line.style_solid, width=2)
        label.new(bar_index, lastSwingLow, bearishChoch ? "CHoCH" : "BOS", style=label.style_label_up, color=color.red, textcolor=color.white, yloc=yloc.price)

// ═════════════════════════════════════════════════════════════════════════════
// INDUCEMENT DETECTION
// ═════════════════════════════════════════════════════════════════════════════
var float induceHigh    = na
var float induceLow     = na

induceSwingHigh = ta.pivothigh(high, induceSwingLen, induceSwingLen)
induceSwingLow  = ta.pivotlow(low, induceSwingLen, induceSwingLen)

if not na(induceSwingHigh)
    induceHigh := induceSwingHigh
if not na(induceSwingLow)
    induceLow := induceSwingLow

bullishInduce = useInducement and marketStructure == "bullish" and not na(induceLow[1]) and low < induceLow[1] and close > induceLow[1]
bearishInduce = useInducement and marketStructure == "bearish" and not na(induceHigh[1]) and high > induceHigh[1] and close < induceHigh[1]

if not showOnlyEntries and showInduceLbl and bullishInduce
    label.new(bar_index, low, "Ind▲", style=label.style_label_up, color=color.teal, textcolor=color.white, yloc=yloc.belowbar)
if not showOnlyEntries and showInduceLbl and bearishInduce
    label.new(bar_index, high, "Ind▼", style=label.style_label_down, color=color.orange, textcolor=color.white, yloc=yloc.abovebar)

// ═════════════════════════════════════════════════════════════════════════════
// FVG FILTER
// ═════════════════════════════════════════════════════════════════════════════
bullFvg = low > high[2]
bearFvg = high < low[2]

fvgSizePips(x, y) => math.abs(x - y) / pipFactor

bullFvgValid = useFvg ? bullFvg and fvgSizePips(low, high[2]) >= fvgThreshold : true
bearFvgValid = useFvg ? bearFvg and fvgSizePips(high, low[2]) >= fvgThreshold : true

// ═════════════════════════════════════════════════════════════════════════════
// ORDER BLOCK FILTER
// ═════════════════════════════════════════════════════════════════════════════
isBullOb() =>
    bool ob = false
    for i = 1 to obLookback
        if close[i] < open[i] and high[i] >= high[i+1] and high[i] >= high[i-1]
            ob := true
    ob

isBearOb() =>
    bool ob = false
    for i = 1 to obLookback
        if close[i] > open[i] and low[i] <= low[i+1] and low[i] <= low[i-1]
            ob := true
    ob

bullObValid = useOb ? isBullOb() : true
bearObValid = useOb ? isBearOb() : true

// ═════════════════════════════════════════════════════════════════════════════
// ENTRY SIGNALS
// ═════════════════════════════════════════════════════════════════════════════
longEntry  = bullishInduce and bullFvgValid and bullObValid and marketStructure == "bullish"
shortEntry = bearishInduce and bearFvgValid and bearObValid and marketStructure == "bearish"

plotshape(longEntry, title="Buy", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, text="BUY", size=size.normal)
plotshape(shortEntry, title="Sell", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, text="SELL", size=size.normal)

// Debug labels
if showDebug and bullishInduce and not longEntry
    reason = not bullFvgValid ? "No FVG" : not bullObValid ? "No OB" : "?"
    label.new(bar_index, low, reason, style=label.style_label_up, color=color.gray, textcolor=color.white, yloc=yloc.belowbar, size=size.small)
if showDebug and bearishInduce and not shortEntry
    reason = not bearFvgValid ? "No FVG" : not bearObValid ? "No OB" : "?"
    label.new(bar_index, high, reason, style=label.style_label_down, color=color.gray, textcolor=color.white, yloc=yloc.abovebar, size=size.small)

// ═════════════════════════════════════════════════════════════════════════════
// STOP LOSS & TAKE PROFIT
// ═════════════════════════════════════════════════════════════════════════════
if longEntry and showTargets
    slPrice = close - atr * atrMult
    tpPrice = close + (close - slPrice) * riskReward
    line.new(bar_index, slPrice, bar_index + 20, slPrice, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, tpPrice, bar_index + 20, tpPrice, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index, slPrice, "SL", style=label.style_label_up, color=color.red, textcolor=color.white, yloc=yloc.price)
    label.new(bar_index, tpPrice, "TP", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

if shortEntry and showTargets
    slPrice = close + atr * atrMult
    tpPrice = close - (slPrice - close) * riskReward
    line.new(bar_index, slPrice, bar_index + 20, slPrice, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, tpPrice, bar_index + 20, tpPrice, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index, slPrice, "SL", style=label.style_label_down, color=color.red, textcolor=color.white, yloc=yloc.price)
    label.new(bar_index, tpPrice, "TP", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

// ═════════════════════════════════════════════════════════════════════════════
// WINRATE TRACKING
// ═════════════════════════════════════════════════════════════════════════════
var array<float> entryPrices = array.new_float(0)
var array<float> slPrices    = array.new_float(0)
var array<float> tpPrices    = array.new_float(0)
var array<int>   directions  = array.new_int(0)
var array<int>   outcomes    = array.new_int(0)

addSignal(dir, entry, sl, tp) =>
    array.push(entryPrices, entry)
    array.push(slPrices, sl)
    array.push(tpPrices, tp)
    array.push(directions, dir)
    array.push(outcomes, 0)
    if array.size(entryPrices) > maxSignals
        array.shift(entryPrices)
        array.shift(slPrices)
        array.shift(tpPrices)
        array.shift(directions)
        array.shift(outcomes)

if longEntry
    sl = close - atr * atrMult
    tp = close + (close - sl) * riskReward
    addSignal(1, close, sl, tp)

if shortEntry
    sl = close + atr * atrMult
    tp = close - (sl - close) * riskReward
    addSignal(-1, close, sl, tp)

size = array.size(entryPrices)
if size > 0
    for i = 0 to size - 1
        if array.get(outcomes, i) == 0
            dir = array.get(directions, i)
            sl  = array.get(slPrices, i)
            tp  = array.get(tpPrices, i)
            if dir == 1
                if low <= sl
                    array.set(outcomes, i, -1)
                else if high >= tp
                    array.set(outcomes, i, 1)
            else
                if high >= sl
                    array.set(outcomes, i, -1)
                else if low <= tp
                    array.set(outcomes, i, 1)

longWins    = 0
longLosses  = 0
shortWins   = 0
shortLosses = 0
longWinPips = 0.0
longLossPips= 0.0
shortWinPips= 0.0
shortLossPips=0.0

if size > 0
    for i = 0 to size - 1
        dir = array.get(directions, i)
        out = array.get(outcomes, i)
        entry = array.get(entryPrices, i)
        sl = array.get(slPrices, i)
        tp = array.get(tpPrices, i)
        if out == 1
            if dir == 1
                longWins += 1
                longWinPips += (tp - entry) / pipFactor
            else
                shortWins += 1
                shortWinPips += (entry - tp) / pipFactor
        else if out == -1
            if dir == 1
                longLosses += 1
                longLossPips += (entry - sl) / pipFactor
            else
                shortLosses += 1
                shortLossPips += (sl - entry) / pipFactor

longTotal    = longWins + longLosses
shortTotal   = shortWins + shortLosses
totalWins    = longWins + shortWins
totalLosses  = longLosses + shortLosses
total        = totalWins + totalLosses

longWinrate  = longTotal > 0 ? (longWins / longTotal) * 100 : 0.0
shortWinrate = shortTotal > 0 ? (shortWins / shortTotal) * 100 : 0.0
totalWinrate = total > 0 ? (totalWins / total) * 100 : 0.0

avgLongWin   = longWins > 0 ? longWinPips / longWins : 0.0
avgLongLoss  = longLosses > 0 ? longLossPips / longLosses : 0.0
avgShortWin  = shortWins > 0 ? shortWinPips / shortWins : 0.0
avgShortLoss = shortLosses > 0 ? shortLossPips / shortLosses : 0.0

// ═════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═════════════════════════════════════════════════════════════════════════════
alertcondition(longEntry, title="Long Entry", message='Inducement Long on {{ticker}} @ {{close}}')
alertcondition(shortEntry, title="Short Entry", message='Inducement Short on {{ticker}} @ {{close}}')

// ═════════════════════════════════════════════════════════════════════════════
// INFO PANEL
// ═════════════════════════════════════════════════════════════════════════════
tableRows = showWinrate ? 12 : 4
var table infoPanel = table.new(position.top_right, 2, tableRows, bgcolor=color.black, border_width=1, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(infoPanel, 0, 0, "Structure", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, marketStructure, text_color=marketStructure == "bullish" ? color.green : marketStructure == "bearish" ? color.red : color.gray, text_size=size.small)
    table.cell(infoPanel, 0, 1, "Swing High", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, str.tostring(lastSwingHigh, format.mintick), text_color=color.red, text_size=size.small)
    table.cell(infoPanel, 0, 2, "Swing Low", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, str.tostring(lastSwingLow, format.mintick), text_color=color.green, text_size=size.small)
    table.cell(infoPanel, 0, 3, "Signal", text_color=color.white, text_size=size.small)
    sigText = longEntry ? "BUY" : shortEntry ? "SELL" : "NONE"
    sigColor= longEntry ? color.green : shortEntry ? color.red : color.gray
    table.cell(infoPanel, 1, 3, sigText, text_color=sigColor, text_size=size.small)
    
    if showWinrate
        table.cell(infoPanel, 0, 4, "Long WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 4, str.tostring(longWinrate, "#.##") + "% (" + str.tostring(longWins) + "/" + str.tostring(longTotal) + ")", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 5, "Long Avg Win", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 5, str.tostring(avgLongWin, "#.##") + " p", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 6, "Long Avg Loss", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 6, str.tostring(avgLongLoss, "#.##") + " p", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 7, "Short WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 7, str.tostring(shortWinrate, "#.##") + "% (" + str.tostring(shortWins) + "/" + str.tostring(shortTotal) + ")", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 8, "Short Avg Win", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 8, str.tostring(avgShortWin, "#.##") + " p", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 9, "Short Avg Loss", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 9, str.tostring(avgShortLoss, "#.##") + " p", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 10, "Total WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 10, str.tostring(totalWinrate, "#.##") + "%", text_color=totalWinrate >= 50 ? color.green : color.red, text_size=size.small)
        table.cell(infoPanel, 0, 11, "Open Trades", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 11, str.tostring(size - totalWins - totalLosses), text_color=color.gray, text_size=size.small)
