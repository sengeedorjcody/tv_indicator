//@version=5
// Overlay indicator — Regime-Aware Adaptive SMC Inducement System
indicator("Inducement SMC Adaptive", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ═════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═════════════════════════════════════════════════════════════════════════════
groupDisplay = "Display Settings"
showOnlyEntries= input.bool(false, "Show Only Entry Signals", group=groupDisplay)
showSwings     = input.bool(true, "Show Swing Highs/Lows", group=groupDisplay)
showBosChoch   = input.bool(true, "Show BOS / CHoCH", group=groupDisplay)
showInduceLbl  = input.bool(true, "Show Inducement Labels", group=groupDisplay)
showTargets    = input.bool(true, "Show TP / SL", group=groupDisplay)
showDebug      = input.bool(false, "Show Debug Info", group=groupDisplay)

groupSettings = "Swing / Structure Settings"
swingLen      = input.int(5, "Swing Lookback", minval=1, group=groupSettings)
induceSwingLen= input.int(3, "Inducement Swing Lookback", minval=1, group=groupSettings)

groupHtf = "Higher-Timeframe Filter"
useHtfFilter  = input.bool(true, "Use HTF Filter", group=groupHtf)
htfTimeframe  = input.timeframe("60", "HTF Timeframe", group=groupHtf)
htfEmaPeriod  = input.int(50, "HTF EMA Period", minval=1, group=groupHtf)

groupEntry = "Entry Settings"
filterMode    = input.string("None", "Signal Filter Mode", options=["None", "FVG only", "OB only", "FVG + OB"], group=groupEntry)
fvgThreshold  = input.float(0.0, "Min FVG Size (pips)", minval=0.0, step=0.1, group=groupEntry)
obLookback    = input.int(5, "Order Block Lookback", minval=1, group=groupEntry)
useEmaFilter  = input.bool(true, "Use EMA Trend Filter", group=groupEntry)
emaPeriod     = input.int(200, "EMA Period", minval=1, group=groupEntry)
useCloseConf  = input.bool(true, "Wait for Candle Close Confirmation", group=groupEntry)
useAdxFilter  = input.bool(true, "Use ADX Filter", group=groupEntry)
adxPeriod     = input.int(14, "ADX Period", minval=1, group=groupEntry)
adxThreshold  = input.float(20.0, "Min ADX", minval=0.0, step=1.0, group=groupEntry)
useVolumeFilter = input.bool(false, "Use Volume Confirmation", group=groupEntry)
volLookback   = input.int(20, "Volume Avg Lookback", minval=1, group=groupEntry)
useConfluence = input.bool(true, "Use Confluence Score", group=groupEntry)
minScore      = input.int(60, "Minimum Confluence Score", minval=0, maxval=100, group=groupEntry)

groupSession = "Session Filter"
useSessionFilter = input.bool(false, "Use Session Filter", group=groupSession)
sessionRange = input.session("0800-1700", "Trading Session", group=groupSession)

groupRegime = "Regime & Adaptive R:R"
useRegime     = input.bool(true, "Use Regime Detection", group=groupRegime)
useDynamicRR  = input.bool(true, "Use Dynamic Risk:Reward", group=groupRegime)
volatileRRMult= input.float(1.5, "Volatile R:R Multiplier", minval=0.1, step=0.1, group=groupRegime)
rangeRRMult   = input.float(0.7, "Range R:R Multiplier", minval=0.1, step=0.1, group=groupRegime)
useAdaptiveSL = input.bool(true, "Use Adaptive SL", group=groupRegime)
lowVolSlMult  = input.float(0.7, "Low Vol SL Multiplier", minval=0.1, step=0.1, group=groupRegime)
highVolSlMult = input.float(1.4, "High Vol SL Multiplier", minval=0.1, step=0.1, group=groupRegime)

groupSl = "Stop Loss / Take Profit"
slMode        = input.string("Fixed percent", "SL Mode", options=["ATR based", "Inducement level", "Fixed percent"], group=groupSl)
atrPeriod     = input.int(14, "ATR Period", group=groupSl)
atrMult       = input.float(1.0, "ATR Multiplier", minval=0.1, step=0.1, group=groupSl)
slPercent     = input.float(0.3, "SL Percent (%)", minval=0.01, step=0.05, group=groupSl)
maxSLPips     = input.float(0.0, "Max SL in pips (0 = disabled)", minval=0.0, step=1.0, group=groupSl)
riskReward    = input.float(2.0, "Base Risk:Reward", minval=0.1, step=0.1, group=groupSl)

groupExit = "Exit Management"
useBreakeven  = input.bool(true, "Move to Breakeven", group=groupExit)
beTrigger     = input.float(50.0, "Breakeven Trigger (% of TP distance)", minval=1.0, maxval=99.0, step=1.0, group=groupExit)
useTrailing   = input.bool(true, "Use Trailing Stop", group=groupExit)
trailAtrMult  = input.float(1.5, "Trailing ATR Multiplier", minval=0.1, step=0.1, group=groupExit)
useTimeExit   = input.bool(false, "Use Time-Based Exit", group=groupExit)
maxBarsInTrade= input.int(20, "Max Bars in Trade", minval=1, group=groupExit)

groupWinrate = "Winrate Stats"
showWinrate   = input.bool(true, "Show Winrate Statistics", group=groupWinrate)
maxSignals    = input.int(200, "Max Signals to Track", minval=10, group=groupWinrate)

// ═════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═════════════════════════════════════════════════════════════════════════════
pipFactor = syminfo.mintick * 10
atr = ta.atr(atrPeriod)
ema = ta.ema(close, emaPeriod)
[diPlus, diMinus, adxValue] = ta.dmi(adxPeriod, adxPeriod)

useFvg = filterMode == "FVG only" or filterMode == "FVG + OB"
useOb  = filterMode == "OB only" or filterMode == "FVG + OB"

inSession = useSessionFilter ? time(timeframe.period, sessionRange) != 0 : true

// HTF data
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], lookahead=barmerge.lookahead_on)
htfEma   = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, htfEmaPeriod)[1], lookahead=barmerge.lookahead_on)
htfBullish = useHtfFilter ? htfClose > htfEma : true
htfBearish = useHtfFilter ? htfClose < htfEma : true

// Volume
avgVolume = ta.sma(volume, volLookback)
volOk = useVolumeFilter ? volume > avgVolume : true

// ═════════════════════════════════════════════════════════════════════════════
// REGIME DETECTION
// ═════════════════════════════════════════════════════════════════════════════
emaSlope = ema - ema[5]
atrRank = ta.percentrank(atr, 50)
isHighVol = atrRank >= 70
isLowVol = atrRank <= 30
isTrending = adxValue >= adxThreshold
isVolatile = isHighVol and isTrending
isRanging = not isTrending

regimeText = isVolatile ? "Volatile" : isTrending ? "Trending" : isRanging ? "Ranging" : "Neutral"

// Adaptive multiplier
volMult = useAdaptiveSL ? (isHighVol ? highVolSlMult : isLowVol ? lowVolSlMult : 1.0) : 1.0

// ═════════════════════════════════════════════════════════════════════════════
// SWING POINTS
// ═════════════════════════════════════════════════════════════════════════════
var float lastSwingHigh    = na
var float lastSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

if not na(swingHigh)
    lastSwingHigh    := swingHigh
    lastSwingHighBar := bar_index[swingLen]
if not na(swingLow)
    lastSwingLow    := swingLow
    lastSwingLowBar := bar_index[swingLen]

plotshape(not showOnlyEntries and showSwings and not na(swingHigh), title="Swing High", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, offset=-swingLen)
plotshape(not showOnlyEntries and showSwings and not na(swingLow), title="Swing Low", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, offset=-swingLen)

// ═════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE (BOS / CHoCH)
// ═════════════════════════════════════════════════════════════════════════════
var string marketStructure = "neutral"

bullishBos  = close > lastSwingHigh and marketStructure != "bullish"
bearishBos  = close < lastSwingLow  and marketStructure != "bearish"
bullishChoch = close > lastSwingHigh and marketStructure == "bearish"
bearishChoch = close < lastSwingLow  and marketStructure == "bullish"

if bullishBos or bullishChoch
    marketStructure := "bullish"
    if not showOnlyEntries and showBosChoch
        line.new(lastSwingHighBar, lastSwingHigh, bar_index, lastSwingHigh, color=color.green, style=line.style_solid, width=2)
        label.new(bar_index, lastSwingHigh, bullishChoch ? "CHoCH" : "BOS", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

if bearishBos or bearishChoch
    marketStructure := "bearish"
    if not showOnlyEntries and showBosChoch
        line.new(lastSwingLowBar, lastSwingLow, bar_index, lastSwingLow, color=color.red, style=line.style_solid, width=2)
        label.new(bar_index, lastSwingLow, bearishChoch ? "CHoCH" : "BOS", style=label.style_label_up, color=color.red, textcolor=color.white, yloc=yloc.price)

// ═════════════════════════════════════════════════════════════════════════════
// INDUCEMENT DETECTION
// ═════════════════════════════════════════════════════════════════════════════
var float induceHigh    = na
var float induceLow     = na

induceSwingHigh = ta.pivothigh(high, induceSwingLen, induceSwingLen)
induceSwingLow  = ta.pivotlow(low, induceSwingLen, induceSwingLen)

if not na(induceSwingHigh)
    induceHigh := induceSwingHigh
if not na(induceSwingLow)
    induceLow := induceSwingLow

bullishInduce = useInducement and marketStructure == "bullish" and not na(induceLow[1]) and low < induceLow[1] and close > induceLow[1]
bearishInduce = useInducement and marketStructure == "bearish" and not na(induceHigh[1]) and high > induceHigh[1] and close < induceHigh[1]

if not showOnlyEntries and showInduceLbl and bullishInduce
    label.new(bar_index, low, "Ind▲", style=label.style_label_up, color=color.teal, textcolor=color.white, yloc=yloc.belowbar)
if not showOnlyEntries and showInduceLbl and bearishInduce
    label.new(bar_index, high, "Ind▼", style=label.style_label_down, color=color.orange, textcolor=color.white, yloc=yloc.abovebar)

// ═════════════════════════════════════════════════════════════════════════════
// FVG & OB FILTERS
// ═════════════════════════════════════════════════════════════════════════════
bullFvg = low > high[2]
bearFvg = high < low[2]

fvgSizePips(x, y) => math.abs(x - y) / pipFactor

bullFvgValid = useFvg ? bullFvg and fvgSizePips(low, high[2]) >= fvgThreshold : true
bearFvgValid = useFvg ? bearFvg and fvgSizePips(high, low[2]) >= fvgThreshold : true

isBullOb() =>
    bool ob = false
    for i = 1 to obLookback
        if close[i] < open[i] and high[i] >= high[i+1] and high[i] >= high[i-1]
            ob := true
    ob

isBearOb() =>
    bool ob = false
    for i = 1 to obLookback
        if close[i] > open[i] and low[i] <= low[i+1] and low[i] <= low[i-1]
            ob := true
    ob

bullObValid = useOb ? isBullOb() : true
bearObValid = useOb ? isBearOb() : true

// ═════════════════════════════════════════════════════════════════════════════
// CONFLUENCE SCORING
// ═════════════════════════════════════════════════════════════════════════════
scoreHtfLong  = useHtfFilter and htfBullish ? 25 : 0
scoreHtfShort = useHtfFilter and htfBearish ? 25 : 0
scoreEmaLong  = useEmaFilter and close > ema ? 15 : 0
scoreEmaShort = useEmaFilter and close < ema ? 15 : 0
scoreAdx      = useAdxFilter and adxValue >= adxThreshold ? 15 : 0
scoreVol      = useVolumeFilter and volOk ? 10 : 0
scoreFvgLong  = useFvg and bullFvgValid ? 15 : 0
scoreFvgShort = useFvg and bearFvgValid ? 15 : 0
scoreObLong   = useOb and bullObValid ? 15 : 0
scoreObShort  = useOb and bearObValid ? 15 : 0
scoreSession  = useSessionFilter and inSession ? 5 : 0

longScore  = scoreHtfLong + scoreEmaLong + scoreAdx + scoreVol + scoreFvgLong + scoreObLong + scoreSession
shortScore = scoreHtfShort + scoreEmaShort + scoreAdx + scoreVol + scoreFvgShort + scoreObShort + scoreSession

// If filters are disabled, ensure score is max so it does not block
longScore  := useConfluence ? longScore : 100
shortScore := useConfluence ? shortScore : 100

// ═════════════════════════════════════════════════════════════════════════════
// ENTRY SIGNALS
// ═════════════════════════════════════════════════════════════════════════════
emaLongOk  = useEmaFilter ? close > ema : true
emaShortOk = useEmaFilter ? close < ema : true
adxOk      = useAdxFilter ? adxValue >= adxThreshold : true

longEntryRaw  = bullishInduce and bullFvgValid and bullObValid and marketStructure == "bullish" and emaLongOk and adxOk and htfBullish and inSession and volOk and longScore >= minScore
shortEntryRaw = bearishInduce and bearFvgValid and bearObValid and marketStructure == "bearish" and emaShortOk and adxOk and htfBearish and inSession and volOk and shortScore >= minScore

longEntry  = useCloseConf ? longEntryRaw[1] : longEntryRaw
shortEntry = useCloseConf ? shortEntryRaw[1] : shortEntryRaw

plotshape(longEntry, title="Buy", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, text="BUY", size=size.normal)
plotshape(shortEntry, title="Sell", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, text="SELL", size=size.normal)

// Debug labels
if showDebug and bullishInduce and not longEntryRaw
    reason = not htfBullish ? "HTF" : not adxOk ? "ADX" : not emaLongOk ? "EMA" : not volOk ? "VOL" : not inSession ? "Session" : longScore < minScore ? "Score" + str.tostring(longScore) : "?"
    label.new(bar_index, low, reason, style=label.style_label_up, color=color.gray, textcolor=color.white, yloc=yloc.belowbar, size=size.small)
if showDebug and bearishInduce and not shortEntryRaw
    reason = not htfBearish ? "HTF" : not adxOk ? "ADX" : not emaShortOk ? "EMA" : not volOk ? "VOL" : not inSession ? "Session" : shortScore < minScore ? "Score" + str.tostring(shortScore) : "?"
    label.new(bar_index, high, reason, style=label.style_label_down, color=color.gray, textcolor=color.white, yloc=yloc.abovebar, size=size.small)

// ═════════════════════════════════════════════════════════════════════════════
// SL / TP / DYNAMIC R:R
// ═════════════════════════════════════════════════════════════════════════════
rrForTrade(isLong) =>
    float rr = riskReward
    if useDynamicRR and useRegime
        rr := isVolatile ? riskReward * volatileRRMult : isRanging ? riskReward * rangeRRMult : riskReward
    rr

calcLongSL() =>
    float sl = na
    if slMode == "Inducement level"
        sl := induceLow[1] - atr * 0.3 * volMult
    else if slMode == "Fixed percent"
        sl := close * (1 - slPercent / 100 * volMult)
    else
        sl := close - atr * atrMult * volMult
    if maxSLPips > 0 and not na(sl)
        maxSlPrice = close - maxSLPips * pipFactor
        sl := math.max(sl, maxSlPrice)
    sl

calcShortSL() =>
    float sl = na
    if slMode == "Inducement level"
        sl := induceHigh[1] + atr * 0.3 * volMult
    else if slMode == "Fixed percent"
        sl := close * (1 + slPercent / 100 * volMult)
    else
        sl := close + atr * atrMult * volMult
    if maxSLPips > 0 and not na(sl)
        maxSlPrice = close + maxSLPips * pipFactor
        sl := math.min(sl, maxSlPrice)
    sl

if longEntry and showTargets
    slPrice = calcLongSL()
    rr = rrForTrade(true)
    tpPrice = close + (close - slPrice) * rr
    if not na(slPrice)
        line.new(bar_index, slPrice, bar_index + 20, slPrice, color=color.red, style=line.style_dashed, width=1)
        line.new(bar_index, tpPrice, bar_index + 20, tpPrice, color=color.green, style=line.style_dashed, width=1)
        label.new(bar_index, slPrice, "SL", style=label.style_label_up, color=color.red, textcolor=color.white, yloc=yloc.price)
        label.new(bar_index, tpPrice, "TP", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

if shortEntry and showTargets
    slPrice = calcShortSL()
    rr = rrForTrade(false)
    tpPrice = close - (slPrice - close) * rr
    if not na(slPrice)
        line.new(bar_index, slPrice, bar_index + 20, slPrice, color=color.red, style=line.style_dashed, width=1)
        line.new(bar_index, tpPrice, bar_index + 20, tpPrice, color=color.green, style=line.style_dashed, width=1)
        label.new(bar_index, slPrice, "SL", style=label.style_label_down, color=color.red, textcolor=color.white, yloc=yloc.price)
        label.new(bar_index, tpPrice, "TP", style=label.style_label_down, color=color.green, textcolor=color.white, yloc=yloc.price)

// ═════════════════════════════════════════════════════════════════════════════
// WINRATE TRACKING WITH BREAKEVEN / TRAILING / TIME EXIT
// ═════════════════════════════════════════════════════════════════════════════
var array<float> entryPrices = array.new_float(0)
var array<float> slPrices    = array.new_float(0)
var array<float> tpPrices    = array.new_float(0)
var array<float> bePrices    = array.new_float(0)
var array<int>   directions  = array.new_int(0)
var array<int>   outcomes    = array.new_int(0)
var array<int>   entryBars   = array.new_int(0)
var array<float> highPrices  = array.new_float(0)
var array<float> lowPrices   = array.new_float(0)

addSignal(dir, entry, sl, tp, be, barIdx) =>
    array.push(entryPrices, entry)
    array.push(slPrices, sl)
    array.push(tpPrices, tp)
    array.push(bePrices, be)
    array.push(directions, dir)
    array.push(outcomes, 0)
    array.push(entryBars, barIdx)
    array.push(highPrices, high)
    array.push(lowPrices, low)
    if array.size(entryPrices) > maxSignals
        array.shift(entryPrices)
        array.shift(slPrices)
        array.shift(tpPrices)
        array.shift(bePrices)
        array.shift(directions)
        array.shift(outcomes)
        array.shift(entryBars)
        array.shift(highPrices)
        array.shift(lowPrices)

if longEntry
    sl = calcLongSL()
    rr = rrForTrade(true)
    tp = close + (close - sl) * rr
    be = close + (tp - close) * (beTrigger / 100)
    if not na(sl)
        addSignal(1, close, sl, tp, be, bar_index)

if shortEntry
    sl = calcShortSL()
    rr = rrForTrade(false)
    tp = close - (sl - close) * rr
    be = close - (close - tp) * (beTrigger / 100)
    if not na(sl)
        addSignal(-1, close, sl, tp, be, bar_index)

size = array.size(entryPrices)
if size > 0
    for i = 0 to size - 1
        if array.get(outcomes, i) == 0
            dir = array.get(directions, i)
            sl  = array.get(slPrices, i)
            tp  = array.get(tpPrices, i)
            be  = array.get(bePrices, i)
            entryBar = array.get(entryBars, i)
            highestSince = array.get(highPrices, i)
            lowestSince = array.get(lowPrices, i)
            
            // Update trailing high/low
            highestSince := math.max(highestSince, high)
            lowestSince := math.min(lowestSince, low)
            array.set(highPrices, i, highestSince)
            array.set(lowPrices, i, lowestSince)
            
            // Breakeven / trailing adjustment
            if useBreakeven
                if dir == 1 and high >= be
                    sl := math.max(sl, array.get(entryPrices, i))
                if dir == -1 and low <= be
                    sl := math.min(sl, array.get(entryPrices, i))
            if useTrailing
                if dir == 1
                    trailSl = highestSince - atr * trailAtrMult
                    sl := math.max(sl, trailSl)
                if dir == -1
                    trailSl = lowestSince + atr * trailAtrMult
                    sl := math.min(sl, trailSl)
            array.set(slPrices, i, sl)
            
            // Check TP / SL / time exit
            if dir == 1
                if low <= sl
                    array.set(outcomes, i, -1)
                else if high >= tp
                    array.set(outcomes, i, 1)
                else if useTimeExit and (bar_index - entryBar) >= maxBarsInTrade
                    array.set(outcomes, i, close > array.get(entryPrices, i) ? 1 : -1)
            else
                if high >= sl
                    array.set(outcomes, i, -1)
                else if low <= tp
                    array.set(outcomes, i, 1)
                else if useTimeExit and (bar_index - entryBar) >= maxBarsInTrade
                    array.set(outcomes, i, close < array.get(entryPrices, i) ? 1 : -1)

longWins    = 0
longLosses  = 0
shortWins   = 0
shortLosses = 0
longWinPips = 0.0
longLossPips= 0.0
shortWinPips= 0.0
shortLossPips=0.0

if size > 0
    for i = 0 to size - 1
        dir = array.get(directions, i)
        out = array.get(outcomes, i)
        entry = array.get(entryPrices, i)
        sl = array.get(slPrices, i)
        tp = array.get(tpPrices, i)
        if out == 1
            if dir == 1
                longWins += 1
                longWinPips += (tp - entry) / pipFactor
            else
                shortWins += 1
                shortWinPips += (entry - tp) / pipFactor
        else if out == -1
            if dir == 1
                longLosses += 1
                longLossPips += (entry - sl) / pipFactor
            else
                shortLosses += 1
                shortLossPips += (sl - entry) / pipFactor

longTotal    = longWins + longLosses
shortTotal   = shortWins + shortLosses
totalWins    = longWins + shortWins
totalLosses  = longLosses + shortLosses
total        = totalWins + totalLosses

longWinrate  = longTotal > 0 ? (longWins / longTotal) * 100 : 0.0
shortWinrate = shortTotal > 0 ? (shortWins / shortTotal) * 100 : 0.0
totalWinrate = total > 0 ? (totalWins / total) * 100 : 0.0

avgLongWin   = longWins > 0 ? longWinPips / longWins : 0.0
avgLongLoss  = longLosses > 0 ? longLossPips / longLosses : 0.0
avgShortWin  = shortWins > 0 ? shortWinPips / shortWins : 0.0
avgShortLoss = shortLosses > 0 ? shortLossPips / shortLosses : 0.0

// ═════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═════════════════════════════════════════════════════════════════════════════
alertcondition(longEntry, title="Long Entry", message='Inducement Long on {{ticker}} @ {{close}}')
alertcondition(shortEntry, title="Short Entry", message='Inducement Short on {{ticker}} @ {{close}}')

// ═════════════════════════════════════════════════════════════════════════════
// INFO PANEL
// ═════════════════════════════════════════════════════════════════════════════
tableRows = showWinrate ? 14 : 6
var table infoPanel = table.new(position.top_right, 2, tableRows, bgcolor=color.black, border_width=1, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(infoPanel, 0, 0, "Structure", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, marketStructure, text_color=marketStructure == "bullish" ? color.green : marketStructure == "bearish" ? color.red : color.gray, text_size=size.small)
    table.cell(infoPanel, 0, 1, "Regime", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, regimeText, text_color=isVolatile ? color.orange : isTrending ? color.green : color.gray, text_size=size.small)
    table.cell(infoPanel, 0, 2, "Swing High", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, str.tostring(lastSwingHigh, format.mintick), text_color=color.red, text_size=size.small)
    table.cell(infoPanel, 0, 3, "Swing Low", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 3, str.tostring(lastSwingLow, format.mintick), text_color=color.green, text_size=size.small)
    table.cell(infoPanel, 0, 4, "Signal", text_color=color.white, text_size=size.small)
    sigText = longEntry ? "BUY" : shortEntry ? "SELL" : "NONE"
    sigColor= longEntry ? color.green : shortEntry ? color.red : color.gray
    table.cell(infoPanel, 1, 4, sigText, text_color=sigColor, text_size=size.small)
    table.cell(infoPanel, 0, 5, "Score", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 5, str.tostring(longEntry ? longScore : shortEntry ? shortScore : 0), text_color=color.yellow, text_size=size.small)
    
    if showWinrate
        table.cell(infoPanel, 0, 6, "Long WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 6, str.tostring(longWinrate, "#.##") + "% (" + str.tostring(longWins) + "/" + str.tostring(longTotal) + ")", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 7, "Long Avg Win", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 7, str.tostring(avgLongWin, "#.##") + " p", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 8, "Long Avg Loss", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 8, str.tostring(avgLongLoss, "#.##") + " p", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 9, "Short WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 9, str.tostring(shortWinrate, "#.##") + "% (" + str.tostring(shortWins) + "/" + str.tostring(shortTotal) + ")", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 10, "Short Avg Win", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 10, str.tostring(avgShortWin, "#.##") + " p", text_color=color.green, text_size=size.small)
        table.cell(infoPanel, 0, 11, "Short Avg Loss", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 11, str.tostring(avgShortLoss, "#.##") + " p", text_color=color.red, text_size=size.small)
        table.cell(infoPanel, 0, 12, "Total WR", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 12, str.tostring(totalWinrate, "#.##") + "%", text_color=totalWinrate >= 50 ? color.green : color.red, text_size=size.small)
        table.cell(infoPanel, 0, 13, "Open Trades", text_color=color.white, text_size=size.small)
        table.cell(infoPanel, 1, 13, str.tostring(size - totalWins - totalLosses), text_color=color.gray, text_size=size.small)
