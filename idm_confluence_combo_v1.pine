//@version=6
indicator("IDM × Confluence Combo v1 — Trend Continuation", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=200)

// ═══════════════════════════════════════════════════════════════════
//  IDM × CONFLUENCE COMBO v1 — Трендийн ДУНДААС орох хувилбар
//
//  Inducement Entry v8/v9 + Confluence Master v1 нэгтгэл:
//
//  ① TREND ENGINE (Confluence Master-аас, HTF дээр):
//     Supertrend + EMA50/200 alignment-ийг ДЭЭД TIMEFRAME (default
//     1H) дээр тооцоолно → 5m-ийн жижиг хэлбэлзэлд эргэхгүй,
//     том чиглэлийг тогтвортой барина
//     → Арын фон ӨНГӨӨР ялгана (ногоон=bull, улаан=bear)
//
//  ② ЭРГЭЛТИЙН ХАМГААЛАЛТ (шинэ — гол сайжруулалт):
//     Тренд эргэснээс хойш N бар (default 12) "хориотой бүс" —
//     энэ үед фон шар өнгөтэй, СИГНАЛ ӨГӨХГҮЙ.
//     → Confluence Master-ийн муу байсан эргэлтийн үеийн
//       сигналуудыг бүрэн хаана. Зөвхөн ТОГТСОН трендийн
//       дундах pullback дээр орно.
//
//  ③ ENTRY ENGINE (Inducement v8/v9-өөс):
//     IDM sweep (1-bar + 2-bar) → POI retest (OB/FVG/fallback)
//     → Reversal candle → Entry
//
//  ④ CONFLUENCE SCORE (хоёр индикаторын нэгтгэл, 6 оноо):
//     MACD momentum · RSI зөв бүсэд · BB сайн үнэ ·
//     Volume · ADX>20 · Sweep rejection wick
//
//  Тренд эргэвэл идэвхтэй setup автоматаар цуцлагдана.
// ═══════════════════════════════════════════════════════════════════

// ─── Groups ───
string G_TREND = "① TREND — Supertrend + EMA + Эргэлтийн хамгаалалт"
string G_IDM   = "② IDM Entry Engine"
string G_POI   = "③ POI"
string G_SCR   = "④ Confluence Score"
string G_RISK  = "⑤ Risk"
string G_FLT   = "⑥ Шүүлтүүр"
string G_VIS   = "⑦ Visual"

// ─── ① Trend Inputs ───
string trend_tf   = input.timeframe("60", "Трендийн Timeframe (HTF)", group=G_TREND,
     tooltip="Supertrend + EMA-г ЭНЭ timeframe дээр тооцоолно. 5m chart дээр 60 = 1 цагийн тренд ашиглана гэсэн үг — жижиг pullback-д тренд эргэхгүй, том чиглэл тогтвортой байна. Chart-ийн TF ашиглах бол хоосон болгоно")
int   st_len      = input.int(10,    "Supertrend ATR Length", minval=1, group=G_TREND)
float st_mult     = input.float(3.0, "Supertrend Multiplier", minval=0.5, step=0.5, group=G_TREND)
int   ema_mid     = input.int(50,    "EMA Mid",  minval=10, group=G_TREND)
int   ema_big     = input.int(200,   "EMA Big",  minval=50, group=G_TREND)
bool  use_ema_al  = input.bool(true, "EMA alignment шаардах", group=G_TREND,
     tooltip="LONG: close > EMA200 ба EMA50 > EMA200 (HTF дээр). Унтраавал зөвхөн Supertrend-ээр тренд тодорхойлно")
int   min_tr_age  = input.int(12, "Тренд тогтсон байх min бар", minval=0, maxval=100, group=G_TREND,
     tooltip="Supertrend эргэснээс хойш энэ тооны бар өнгөрөөгүй бол СИГНАЛ ӨГӨХГҮЙ (эргэлтийн бүс). Фон шараар харагдана")
int   max_tr_age  = input.int(0, "Тренд хэт хөгширсөн max бар (0=хязгааргүй)", minval=0, group=G_TREND,
     tooltip="Тренд хэт удаан үргэлжилсэн бол сигнал өгөхгүй. 0 = унтраах")

// ─── ② IDM Inputs ───
int   idm_len     = input.int(4,  "IDM Swing Length",   minval=1,  group=G_IDM)
int   idm_expire  = input.int(60, "IDM Expire (bars)",  minval=10, group=G_IDM)
bool  sweep_2bar  = input.bool(true, "2-bar sweep зөвшөөрөх", group=G_IDM)
float min_sweep_atr = input.float(0.25, "Min Sweep гүн (ATR×)", minval=0.0, step=0.05, group=G_IDM,
     tooltip="Sweep-ийн wick IDM түвшнээс хамгийн багадаа ATR×энэ хэмжээгээр нэвтэрсэн байх. 0 = унтраах")

// ─── ③ POI Inputs ───
bool  use_ob   = input.bool(true, "OB POI ашиглах",  group=G_POI)
bool  use_fvg  = input.bool(true, "FVG POI ашиглах", group=G_POI)
bool  use_fb   = input.bool(true, "Fallback POI (sweep зона)", group=G_POI)
int   poi_wait = input.int(40,    "POI Retest хүлээх (bars)", minval=3, maxval=150, group=G_POI)
bool  use_rev_candle = input.bool(true, "Reversal candle баталгаа", group=G_POI)
float rev_body_min   = input.float(0.35, "Reversal биет/далайц min", minval=0.1, maxval=0.9, step=0.05, group=G_POI)

// ─── ④ Score Inputs ───
int   min_score = input.int(4, "Min Confluence оноо (6-аас)", minval=1, maxval=6, group=G_SCR,
     tooltip="1:MACD momentum 2:RSI зөв бүсэд 3:BB сайн үнэ 4:Volume 5:ADX>20 6:Sweep rejection wick")
int   macd_f    = input.int(12, "MACD Fast",   minval=2, group=G_SCR)
int   macd_s    = input.int(26, "MACD Slow",   minval=5, group=G_SCR)
int   macd_sig  = input.int(9,  "MACD Signal", minval=2, group=G_SCR)
int   rsi_len   = input.int(14, "RSI Length",  minval=2, group=G_SCR)
float rsi_lo_l  = input.float(35, "RSI Long бүс доод", minval=20, maxval=50, group=G_SCR)
float rsi_hi_l  = input.float(65, "RSI Long бүс дээд", minval=50, maxval=80, group=G_SCR)
int   bb_len    = input.int(20,    "BB Length",     minval=5, group=G_SCR)
float bb_mult   = input.float(2.0, "BB Multiplier", minval=0.5, step=0.1, group=G_SCR)
float bb_zone   = input.float(0.45,"BB entry бүс (0-1)", minval=0.1, maxval=0.6, step=0.05, group=G_SCR,
     tooltip="LONG: үнэ BB доод хэсгийн энэ хувьд байвал 'сайн үнэ' оноо авна")
int   vol_len   = input.int(20, "Volume SMA Length", minval=5, group=G_SCR)

// ─── ⑤ Risk ───
bool  use_atr_sl = input.bool(true, "ATR-Adaptive SL", group=G_RISK)
float atr_mult   = input.float(1.0, "ATR SL Mult", minval=0.1, step=0.1, group=G_RISK)
int   atr_len    = input.int(14,    "ATR Length",  minval=1, group=G_RISK)
float rr1        = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_RISK)
float rr2        = input.float(2.0, "TP2 R:R", minval=1.0, step=0.5, group=G_RISK)

// ─── ⑥ Filters ───
bool  use_rsi_x = input.bool(true, "RSI extreme шүүлтүүр (BUY@RSI>70 хориглох)", group=G_FLT)
int   cooldown  = input.int(10, "Сигнал хоорондын зай (bars)", minval=0, maxval=50, group=G_FLT)
bool  use_kz    = input.bool(false, "Killzone цаг (UTC 07-11, 12-16)", group=G_FLT)
bool  use_sess  = input.bool(false, "Custom Session Filter", group=G_FLT)
string sess     = input.session("0800-1700", "Session", group=G_FLT)

// ─── ⑦ Visual ───
color col_bull  = input.color(color.rgb(38, 200, 120), "Bull", group=G_VIS)
color col_bear  = input.color(color.rgb(240, 80, 60),  "Bear", group=G_VIS)
color col_warn  = input.color(color.rgb(255, 190, 0),  "Эргэлтийн бүс", group=G_VIS)
color col_poi   = input.color(color.new(color.rgb(255, 190, 0), 75), "POI Zone", group=G_VIS)
bool  show_bg   = input.bool(true, "Трендийн арын фон",  group=G_VIS)
bool  show_st   = input.bool(true, "Supertrend шугам",   group=G_VIS)
bool  show_ema  = input.bool(true, "EMA шугамууд",       group=G_VIS)
bool  show_idm  = input.bool(true, "IDM тэмдэглэгээ",    group=G_VIS)
bool  show_poi  = input.bool(true, "POI зона харуулах",  group=G_VIS)
bool  show_dash = input.bool(true, "Dashboard",          group=G_VIS)

// ═══════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

float atr_v   = ta.atr(atr_len)
float rsi_v   = ta.rsi(close, rsi_len)
float vol_sma = ta.sma(volume, vol_len)
[di_p, di_m, adx_v] = ta.dmi(14, 14)
[macd_line, signal_line, hist] = ta.macd(close, macd_f, macd_s, macd_sig)

// ─── ① TREND ENGINE: Supertrend + EMA (HTF дээр тооцоолно) ───
// Трендийг дээд timeframe дээр тодорхойлсноор 5m-ийн жижиг
// pullback-д тренд эргэхгүй — таны зурсан шиг ТОМ чиглэл барина
f_trend_calc() =>
    [stl, std] = ta.supertrend(st_mult, st_len)
    [stl, std, ta.ema(close, ema_mid), ta.ema(close, ema_big), close]

[st_line, st_dir, e50, e200, htf_close] = request.security(syminfo.tickerid, trend_tf, f_trend_calc(), lookahead=barmerge.lookahead_off)

bool  st_bull = st_dir < 0
bool  st_bear = st_dir > 0
bool  ema_bull = not use_ema_al or (htf_close > e200 and e50 > e200)
bool  ema_bear = not use_ema_al or (htf_close < e200 and e50 < e200)

int trend = st_bull and ema_bull ? 1 : st_bear and ema_bear ? -1 : 0

// ─── ② ЭРГЭЛТИЙН ХАМГААЛАЛТ: трендийн нас ───
// Supertrend эргэсэн бар = эргэлтийн цэг. Түүнээс хойш min_tr_age
// бар өнгөрөөгүй бол тренд "тогтоогүй" — сигнал хориотой.
var int flip_bar = 0
if st_dir != st_dir[1]
    flip_bar := bar_index
int  tr_age    = bar_index - flip_bar
bool tr_mature = tr_age >= min_tr_age
bool tr_fresh  = trend != 0 and not tr_mature            // эргэлтийн бүс
bool tr_old    = max_tr_age > 0 and tr_age > max_tr_age  // хэт хөгширсөн
bool regime_ok = trend != 0 and tr_mature and not tr_old

// Арын фон: тогтсон тренд = өнгөтэй, эргэлтийн бүс = шар, neutral = байхгүй
color bg_col = not show_bg ? na :
     tr_fresh          ? color.new(col_warn, 88) :
     regime_ok and trend == 1  ? color.new(col_bull, 90) :
     regime_ok and trend == -1 ? color.new(col_bear, 90) : na
bgcolor(bg_col, title="Trend Background")

// ─── Session / Killzone / Cooldown ───
int h_utc = hour(time, "UTC")
bool in_kz   = not use_kz or ((h_utc >= 7 and h_utc < 11) or (h_utc >= 12 and h_utc < 16))
bool in_sess = not use_sess or not na(time(timeframe.period, sess))
bool f_time  = in_kz and in_sess

var int last_sig_bar = -9999
bool cd_ok = bar_index - last_sig_bar >= cooldown

// ─── RSI extreme filter ───
bool f_rsi_l = not use_rsi_x or rsi_v < 70
bool f_rsi_s = not use_rsi_x or rsi_v > 30

// ─── Bollinger (сайн үнэ бүс) ───
float bb_mid = ta.sma(close, bb_len)
float bb_dev = ta.stdev(close, bb_len) * bb_mult
float bb_up  = bb_mid + bb_dev
float bb_dn  = bb_mid - bb_dev
float bb_pos = bb_up != bb_dn ? (close - bb_dn) / (bb_up - bb_dn) : 0.5
bool  bb_low_zone  = bb_pos <= bb_zone
bool  bb_high_zone = bb_pos >= 1 - bb_zone

// ─── MACD momentum ───
bool hist_up   = hist > hist[1]
bool hist_down = hist < hist[1]

// ─── RSI continuation бүс ───
float rsi_lo_s = 100 - rsi_hi_l
float rsi_hi_s = 100 - rsi_lo_l
bool rsi_ok_l = rsi_v >= rsi_lo_l and rsi_v <= rsi_hi_l
bool rsi_ok_s = rsi_v >= rsi_lo_s and rsi_v <= rsi_hi_s

// ─── ③ IDM Detection (тогтсон трендийн доторх жижиг pivot) ───
float iph = ta.pivothigh(high, idm_len, idm_len)
float ipl = ta.pivotlow(low,   idm_len, idm_len)

var float idm_bull_price = na
var int   idm_bull_bar   = na
var float idm_bull_sl    = na
var float idm_bear_price = na
var int   idm_bear_bar   = na
var float idm_bear_sl    = na

if trend == 1 and not na(ipl)
    idm_bull_price := ipl
    idm_bull_bar   := bar_index - idm_len
    idm_bull_sl    := low[idm_len]
if trend == -1 and not na(iph)
    idm_bear_price := iph
    idm_bear_bar   := bar_index - idm_len
    idm_bear_sl    := high[idm_len]

if not na(idm_bull_bar) and bar_index - idm_bull_bar > idm_expire
    idm_bull_price := na
    idm_bull_bar   := na
if not na(idm_bear_bar) and bar_index - idm_bear_bar > idm_expire
    idm_bear_price := na
    idm_bear_bar   := na

// Тренд эргэвэл эсрэг талын IDM хүчингүй
if trend != 1
    idm_bull_price := na
    idm_bull_bar   := na
if trend != -1
    idm_bear_price := na
    idm_bear_bar   := na

// ─── IDM Sweep: 1-bar ба 2-bar ───
bool sw_bull_1 = trend == 1 and not na(idm_bull_price) and low <= idm_bull_price and close > idm_bull_price
bool sw_bull_2 = sweep_2bar and trend == 1 and not na(idm_bull_price) and low[1] <= idm_bull_price and close[1] <= idm_bull_price and close > idm_bull_price
bool sw_bear_1 = trend == -1 and not na(idm_bear_price) and high >= idm_bear_price and close < idm_bear_price
bool sw_bear_2 = sweep_2bar and trend == -1 and not na(idm_bear_price) and high[1] >= idm_bear_price and close[1] >= idm_bear_price and close < idm_bear_price

bool sweep_bull_raw = sw_bull_1 or sw_bull_2
bool sweep_bear_raw = sw_bear_1 or sw_bear_2

float sweep_low_bull  = sw_bull_1 ? low  : math.min(low, low[1])
float sweep_high_bear = sw_bear_1 ? high : math.max(high, high[1])

float sweep_depth_bull = not na(idm_bull_price) ? (idm_bull_price - sweep_low_bull)  / atr_v : na
float sweep_depth_bear = not na(idm_bear_price) ? (sweep_high_bear - idm_bear_price) / atr_v : na

bool sweep_deep_bull = min_sweep_atr <= 0 or (not na(sweep_depth_bull) and sweep_depth_bull >= min_sweep_atr)
bool sweep_deep_bear = min_sweep_atr <= 0 or (not na(sweep_depth_bear) and sweep_depth_bear >= min_sweep_atr)

bool sweep_bull = sweep_bull_raw and sweep_deep_bull
bool sweep_bear = sweep_bear_raw and sweep_deep_bear

// ─── ④ Confluence Score (6 оноо — хоёр индикаторын нэгтгэл) ───
// Тренд (ST+EMA) нь ЗААВАЛ нөхцөл тул оноонд ОРОХГҮЙ — давхардалгүй
f_rej_bull(int off) =>
    float rng = high[off] - low[off]
    rng > 0 and (math.min(open[off], close[off]) - low[off]) / rng >= 0.4

f_rej_bear(int off) =>
    float rng = high[off] - low[off]
    rng > 0 and (high[off] - math.max(open[off], close[off])) / rng >= 0.4

int sw_off_bull = sw_bull_1 ? 0 : 1
int sw_off_bear = sw_bear_1 ? 0 : 1

f_score_long(int off) =>
    int s = 0
    s += hist_up ? 1 : 0              // 1: MACD momentum сэргэж
    s += rsi_ok_l ? 1 : 0             // 2: RSI continuation бүсэд
    s += bb_low_zone ? 1 : 0          // 3: BB доод бүс — сайн үнэ
    s += volume > vol_sma ? 1 : 0     // 4: Volume дэмжсэн
    s += adx_v > 20 ? 1 : 0           // 5: тренд хүчтэй
    s += f_rej_bull(off) ? 1 : 0      // 6: sweep лаанд rejection wick
    s

f_score_short(int off) =>
    int s = 0
    s += hist_down ? 1 : 0
    s += rsi_ok_s ? 1 : 0
    s += bb_high_zone ? 1 : 0
    s += volume > vol_sma ? 1 : 0
    s += adx_v > 20 ? 1 : 0
    s += f_rej_bear(off) ? 1 : 0
    s

// ─── POI Detection ───
f_find_bull_ob() =>
    float t = na
    float b = na
    for j = 1 to 10
        if close[j] < open[j]
            t := high[j]
            b := low[j]
            break
    [t, b]

f_find_bear_ob() =>
    float t = na
    float b = na
    for j = 1 to 10
        if close[j] > open[j]
            t := high[j]
            b := low[j]
            break
    [t, b]

bool  has_bull_fvg = low > high[2]
float bfvg_t = has_bull_fvg ? low     : na
float bfvg_b = has_bull_fvg ? high[2] : na
bool  has_bear_fvg = high < low[2]
float sfvg_t = has_bear_fvg ? low[2]  : na
float sfvg_b = has_bear_fvg ? high    : na

// ─── Setup state machine ───
var int   setup      = 0
var float poi_top    = na
var float poi_bot    = na
var float setup_sl   = na
var int   setup_bar  = na
var int   setup_scr  = 0
var box   poi_box    = na

// Тренд эргэвэл эсвэл эргэлтийн бүсэд орвол setup цуцлана
if setup == 1 and trend != 1
    setup := 0
    box.delete(poi_box)
if setup == -1 and trend != -1
    setup := 0
    box.delete(poi_box)

// Bull setup идэвхжүүлэх — ЗӨВХӨН тогтсон bull трендэд
int cur_score_l = f_score_long(sw_off_bull)
if sweep_bull and regime_ok and trend == 1 and f_time and cur_score_l >= min_score
    [ob_t, ob_b] = f_find_bull_ob()
    float pt = na
    float pb = na
    if use_ob and not na(ob_t)
        pt := ob_t
        pb := ob_b
    if use_fvg and not na(bfvg_t) and (na(pt) or bfvg_t < pt)
        pt := bfvg_t
        pb := bfvg_b
    if use_fb and na(pt)
        pt := idm_bull_price
        pb := sweep_low_bull
    if not na(pt) and pt < close
        setup     := 1
        poi_top   := pt
        poi_bot   := pb
        setup_sl  := math.min(idm_bull_sl, pb)
        setup_bar := bar_index
        setup_scr := cur_score_l
        idm_bull_price := na
        if show_idm
            label.new(bar_index, low, "IDM ⤵ " + str.tostring(cur_score_l) + "/6", color=color.new(col_bull, 20), textcolor=color.white, style=label.style_label_up, size=size.small)
        if show_poi
            box.delete(poi_box)
            poi_box := box.new(bar_index, pt, bar_index + poi_wait, pb, border_color=color.new(col_bull, 40), bgcolor=col_poi)

// Bear setup идэвхжүүлэх — ЗӨВХӨН тогтсон bear трендэд
int cur_score_s = f_score_short(sw_off_bear)
if sweep_bear and regime_ok and trend == -1 and f_time and cur_score_s >= min_score
    [ob_t, ob_b] = f_find_bear_ob()
    float pt = na
    float pb = na
    if use_ob and not na(ob_t)
        pt := ob_t
        pb := ob_b
    if use_fvg and not na(sfvg_t) and (na(pb) or sfvg_b > pb)
        pt := sfvg_t
        pb := sfvg_b
    if use_fb and na(pb)
        pt := sweep_high_bear
        pb := idm_bear_price
    if not na(pb) and pb > close
        setup     := -1
        poi_top   := pt
        poi_bot   := pb
        setup_sl  := math.max(idm_bear_sl, pt)
        setup_bar := bar_index
        setup_scr := cur_score_s
        idm_bear_price := na
        if show_idm
            label.new(bar_index, high, "IDM ⤴ " + str.tostring(cur_score_s) + "/6", color=color.new(col_bear, 20), textcolor=color.white, style=label.style_label_down, size=size.small)
        if show_poi
            box.delete(poi_box)
            poi_box := box.new(bar_index, pt, bar_index + poi_wait, pb, border_color=color.new(col_bear, 40), bgcolor=col_poi)

// ─── Adaptive reversal candle ───
float body_req  = setup_scr >= 5 ? rev_body_min * 0.6 : rev_body_min
float bar_range = high - low
float bar_body  = math.abs(close - open)
bool  body_ok   = bar_range > 0 and bar_body / bar_range >= body_req
bool  rev_bull  = not use_rev_candle or (close > open and body_ok)
bool  rev_bear  = not use_rev_candle or (close < open and body_ok)

// ─── Entry: POI retest + reversal + RSI + cooldown ───
bool long_entry  = false
bool short_entry = false
float entry_p    = na
float sl_p       = na

if setup == 1
    if bar_index - setup_bar > poi_wait or close < setup_sl
        setup := 0
        box.delete(poi_box)
    else if low <= poi_top and close > poi_bot and rev_bull and f_rsi_l and cd_ok
        long_entry := true
        entry_p    := math.min(close, poi_top)
        sl_p       := use_atr_sl ? setup_sl - atr_v * atr_mult : setup_sl
        setup      := 0

if setup == -1
    if bar_index - setup_bar > poi_wait or close > setup_sl
        setup := 0
        box.delete(poi_box)
    else if high >= poi_bot and close < poi_top and rev_bear and f_rsi_s and cd_ok
        short_entry := true
        entry_p     := math.max(close, poi_bot)
        sl_p        := use_atr_sl ? setup_sl + atr_v * atr_mult : setup_sl
        setup       := 0

if long_entry or short_entry
    last_sig_bar := bar_index

// ─── TP levels & drawing ───
var line  e_ln  = na
var line  sl_ln = na
var line  t1_ln = na
var line  t2_ln = na
var label e_lb  = na
var label sl_lb = na
var label t1_lb = na
var label t2_lb = na

f_draw(float ep, float sp, float t1, float t2, color c) =>
    line.delete(e_ln)
    line.delete(sl_ln)
    line.delete(t1_ln)
    line.delete(t2_ln)
    label.delete(e_lb)
    label.delete(sl_lb)
    label.delete(t1_lb)
    label.delete(t2_lb)
    int r = bar_index + 30
    e  = line.new(bar_index, ep, r, ep, color=c,           width=2)
    s  = line.new(bar_index, sp, r, sp, color=color.red,   width=1, style=line.style_dashed)
    a  = line.new(bar_index, t1, r, t1, color=color.green, width=1, style=line.style_dashed)
    b  = line.new(bar_index, t2, r, t2, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    el = label.new(r, ep, "Entry "  + str.tostring(ep, format.mintick), color=color.new(c, 75),          textcolor=color.white, style=label.style_label_left, size=size.small)
    sl = label.new(r, sp, "SL "     + str.tostring(sp, format.mintick), color=color.new(color.red, 75),  textcolor=color.white, style=label.style_label_left, size=size.small)
    l1 = label.new(r, t1, "TP1 "    + str.tostring(t1, format.mintick), color=color.new(color.green,75), textcolor=color.white, style=label.style_label_left, size=size.small)
    l2 = label.new(r, t2, "TP2 "    + str.tostring(t2, format.mintick), color=color.new(color.green,85), textcolor=color.white, style=label.style_label_left, size=size.small)
    [e, s, a, b, el, sl, l1, l2]

float risk_l = long_entry  ? entry_p - sl_p : na
float tp1_l  = long_entry  ? entry_p + risk_l * rr1 : na
float tp2_l  = long_entry  ? entry_p + risk_l * rr2 : na
float risk_s = short_entry ? sl_p - entry_p : na
float tp1_s  = short_entry ? entry_p - risk_s * rr1 : na
float tp2_s  = short_entry ? entry_p - risk_s * rr2 : na

if long_entry and risk_l > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_l, tp2_l, col_bull)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

if short_entry and risk_s > 0
    [a, b, c, d, e, f, g, hh] = f_draw(entry_p, sl_p, tp1_s, tp2_s, col_bear)
    e_ln := a
    sl_ln := b
    t1_ln := c
    t2_ln := d
    e_lb := e
    sl_lb := f
    t1_lb := g
    t2_lb := hh

// ─── Plots ───
plot(show_st ? st_line : na, "Supertrend", color=st_bull ? color.new(col_bull, 30) : color.new(col_bear, 30), linewidth=2, style=plot.style_linebr)
plot(show_ema ? e50  : na, "EMA50",  color=color.new(color.orange, 30), linewidth=1)
plot(show_ema ? e200 : na, "EMA200", color=color.new(color.white, 40),  linewidth=2)
plot(idm_bull_price, "Bull IDM", color=color.new(color.rgb(38,200,120), 55), style=plot.style_linebr, linewidth=1)
plot(idm_bear_price, "Bear IDM", color=color.new(color.rgb(240,80,60),  55), style=plot.style_linebr, linewidth=1)

plotshape(long_entry,  "LONG",  shape.labelup,   location.belowbar, color.new(color.rgb(38,200,120), 0), textcolor=color.white, text="BUY\nC1", size=size.normal)
plotshape(short_entry, "SHORT", shape.labeldown, location.abovebar, color.new(color.rgb(240,80,60),  0), textcolor=color.white, text="SELL\nC1", size=size.normal)

// ─── Winrate Tracking (TP1 = WIN + breakeven логик) ───
var int   trade_dir  = 0
var float trade_sl   = na
var float trade_tp1  = na
var float trade_tp2  = na
var int   wins       = 0
var int   losses     = 0
var int   tp2_hits   = 0
var bool  tp1_done   = false
var int   last_sig   = na

if long_entry and risk_l > 0
    trade_dir := 1
    trade_sl  := sl_p
    trade_tp1 := tp1_l
    trade_tp2 := tp2_l
    tp1_done  := false
    last_sig  := bar_index
if short_entry and risk_s > 0
    trade_dir := -1
    trade_sl  := sl_p
    trade_tp1 := tp1_s
    trade_tp2 := tp2_s
    tp1_done  := false
    last_sig  := bar_index

if trade_dir == 1 and not (long_entry or short_entry)
    if not tp1_done and high >= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and high >= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if low <= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

if trade_dir == -1 and not (long_entry or short_entry)
    if not tp1_done and low <= trade_tp1
        tp1_done := true
        wins     := wins + 1
    if tp1_done and low <= trade_tp2
        tp2_hits  := tp2_hits + 1
        trade_dir := 0
    else if high >= trade_sl
        if not tp1_done
            losses := losses + 1
        trade_dir := 0

int   total_trades = wins + losses
float winrate      = total_trades > 0 ? wins / total_trades * 100 : na

// ─── Dashboard ───
var table dash = table.new(position.top_right, 2, 10, border_width=1, border_color=color.rgb(50,50,70), frame_width=1, frame_color=color.rgb(60,60,90))
if show_dash and barstate.islast
    string tr_txt = trend == 1 ? (tr_mature ? "▲ Bull (тогтсон)" : "▲ Bull (шинэ ⚠)") : trend == -1 ? (tr_mature ? "▼ Bear (тогтсон)" : "▼ Bear (шинэ ⚠)") : "○ Neutral"
    color  tr_col = trend == 1 ? col_bull : trend == -1 ? col_bear : color.gray
    string age_txt = str.tostring(tr_age) + " бар" + (regime_ok ? " ✅ сигнал зөвшөөрсөн" : tr_fresh ? " ⚠ эргэлтийн бүс" : tr_old ? " ⚠ хөгширсөн" : " — тренд алга")
    string st_txt = setup == 1 ? "⏳ POI хүлээж (LONG " + str.tostring(setup_scr) + "/6)" : setup == -1 ? "⏳ POI хүлээж (SHORT " + str.tostring(setup_scr) + "/6)" : trade_dir != 0 ? (trade_dir == 1 ? "📈 LONG нээлттэй" : "📉 SHORT нээлттэй") : "○ Idle"
    string sc_txt = "L:" + str.tostring(f_score_long(0)) + "/6  S:" + str.tostring(f_score_short(0)) + "/6"
    string idm_txt = (not na(idm_bull_price) ? "B:" + str.tostring(idm_bull_price, format.mintick) : "") + (not na(idm_bear_price) ? " S:" + str.tostring(idm_bear_price, format.mintick) : "")
    string wr_txt = total_trades > 0 ? str.tostring(winrate, "#.#") + "%  (" + str.tostring(wins) + "W/" + str.tostring(losses) + "L)" : "— арилжаа алга"
    color  wr_col = na(winrate) ? color.gray : winrate >= 60 ? col_bull : winrate >= 50 ? color.rgb(255,200,0) : col_bear
    string tt_txt = str.tostring(total_trades) + " нийт · TP2: " + str.tostring(tp2_hits)
    string ls_txt = not na(last_sig) ? str.tostring(bar_index - last_sig) + " бар өмнө" : "—"
    table.cell(dash, 0, 0, " IDM×Confluence C1", bgcolor=color.rgb(18,22,38), text_color=color.rgb(0,200,255), text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " · " + timeframe.period, bgcolor=color.rgb(18,22,38), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 1, " Trend",       bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 1, tr_txt,         bgcolor=color.rgb(14,17,28), text_color=tr_col, text_size=size.small)
    table.cell(dash, 0, 2, " Трендийн нас",bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 2, age_txt,        bgcolor=color.rgb(10,10,18), text_color=regime_ok ? col_bull : col_warn, text_size=size.small)
    table.cell(dash, 0, 3, " Setup",       bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 3, st_txt,         bgcolor=color.rgb(14,17,28), text_color=color.rgb(255,200,0), text_size=size.small)
    table.cell(dash, 0, 4, " Confluence",  bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 4, sc_txt,         bgcolor=color.rgb(10,10,18), text_color=color.rgb(0,200,255), text_size=size.small)
    table.cell(dash, 0, 5, " IDM",         bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 5, idm_txt == "" ? "—" : idm_txt, bgcolor=color.rgb(14,17,28), text_color=color.rgb(160,175,220), text_size=size.small)
    table.cell(dash, 0, 6, " Winrate",     bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 6, wr_txt,         bgcolor=color.rgb(10,10,18), text_color=wr_col, text_size=size.small)
    table.cell(dash, 0, 7, " Арилжаа",     bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 7, tt_txt,         bgcolor=color.rgb(14,17,28), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(dash, 0, 8, " Сүүлийн сигнал", bgcolor=color.rgb(10,10,18), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 8, ls_txt,         bgcolor=color.rgb(10,10,18), text_color=color.rgb(200,180,255), text_size=size.small)
    table.cell(dash, 0, 9, " RSI · ADX · BB", bgcolor=color.rgb(14,17,28), text_color=color.white, text_halign=text.align_left, text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(rsi_v, "#.#") + " · " + str.tostring(adx_v, "#.#") + " · " + str.tostring(bb_pos * 100, "#") + "%", bgcolor=color.rgb(14,17,28), text_color=color.rgb(160,175,220), text_size=size.small)

// ─── Alerts ───
alertcondition(long_entry,  "Combo C1 LONG",  "IDM×Confluence LONG — {{ticker}} @ {{close}}")
alertcondition(short_entry, "Combo C1 SHORT", "IDM×Confluence SHORT — {{ticker}} @ {{close}}")
alertcondition(setup != 0 and setup[1] == 0, "Combo C1 Setup", "IDM×Confluence SETUP идэвхжлээ — {{ticker}} @ {{close}}")
